{% liquid
  assign block_font = settings.type_body_font
  assign title_size = block.settings.ai_acc_title_size | default: 16
  assign text_size = block.settings.ai_acc_text_size | default: 14
  assign icon_size = block.settings.ai_acc_icon_size | default: 22
  assign divider_thickness = block.settings.ai_acc_divider_thickness | default: 1
  assign item_gap = block.settings.ai_acc_item_gap | default: 14
%}

<style>
  .pa-accordion-{{ block.id }} {
    --pa-text: {{ block.settings.ai_acc_text_color }};
    --pa-muted: {{ block.settings.ai_acc_answer_color }};
    --pa-icon: {{ block.settings.ai_acc_icon_color }};
    --pa-line: {{ block.settings.ai_acc_divider_color }};
    --pa-chevron: {{ block.settings.ai_acc_chevron_color }};
    --pa-title-size: {{ title_size }}px;
    --pa-text-size: {{ text_size }}px;
    --pa-icon-size: {{ icon_size }}px;
    --pa-divider: {{ divider_thickness }}px;
    --pa-gap: {{ item_gap }}px;
    --pa-icon-stroke: {{ block.settings.ai_acc_icon_stroke | default: 1.8 }};
    margin-top: {{ block.settings.ai_acc_margin_top }}px;
    margin-bottom: {{ block.settings.ai_acc_margin_bottom }}px;
    font-family: {{ block_font.family }}, {{ block_font.fallback_families }};
    font-weight: {{ block_font.weight }};
    font-style: {{ block_font.style }};
  }

  .pa-accordion-{{ block.id }} * {
    box-sizing: border-box;
  }

  .pa-accordion-{{ block.id }} .pa-item {
    border-top: var(--pa-divider) solid var(--pa-line);
  }

  .pa-accordion-{{ block.id }} .pa-item:last-child {
    border-bottom: var(--pa-divider) solid var(--pa-line);
  }

  .pa-accordion-{{ block.id }} .pa-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: {{ block.settings.ai_acc_padding_y }}px 0;
  }

  .pa-accordion-{{ block.id }} .pa-summary::-webkit-details-marker {
    display: none;
  }

  .pa-accordion-{{ block.id }} .pa-left {
    display: flex;
    align-items: center;
    gap: var(--pa-gap);
    min-width: 0;
    flex: 1 1 auto;
  }

  .pa-accordion-{{ block.id }} .pa-icon-wrap {
    width: var(--pa-icon-size);
    height: var(--pa-icon-size);
    flex: 0 0 var(--pa-icon-size);
    color: var(--pa-icon);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pa-accordion-{{ block.id }} .pa-icon-wrap svg {
    width: 100%;
    height: 100%;
    display: block;
    stroke: currentColor;
    fill: none;
    stroke-width: var(--pa-icon-stroke);
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .pa-accordion-{{ block.id }} .pa-label {
    color: var(--pa-text);
    font-size: var(--pa-title-size);
    line-height: 1.25;
    font-weight: {{ block.settings.ai_acc_title_weight }};
    letter-spacing: 0;
    word-break: break-word;
  }

  .pa-accordion-{{ block.id }} .pa-arrow {
    width: {{ block.settings.ai_acc_chevron_size }}px;
    height: {{ block.settings.ai_acc_chevron_size }}px;
    flex: 0 0 {{ block.settings.ai_acc_chevron_size }}px;
    color: var(--pa-chevron);
    transition: transform .22s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pa-accordion-{{ block.id }} .pa-arrow svg {
    width: 100%;
    height: 100%;
    display: block;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .pa-accordion-{{ block.id }} .pa-item[open] .pa-arrow {
    transform: rotate(180deg);
  }

  .pa-accordion-{{ block.id }} .pa-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .28s ease, opacity .2s ease;
    opacity: 0;
  }

  .pa-accordion-{{ block.id }} .pa-item[open] .pa-content {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .pa-accordion-{{ block.id }} .pa-content-inner {
    overflow: hidden;
  }

  .pa-accordion-{{ block.id }} .pa-answer {
    padding: 0 0 {{ block.settings.ai_acc_answer_padding_bottom }}px;
    color: var(--pa-muted);
    font-size: var(--pa-text-size);
    line-height: {{ block.settings.ai_acc_text_line_height }};
  }

  .pa-accordion-{{ block.id }} .pa-answer p {
    margin: 0 0 10px;
  }

  .pa-accordion-{{ block.id }} .pa-answer p:last-child {
    margin-bottom: 0;
  }

  .pa-accordion-{{ block.id }} .pa-answer ul,
  .pa-accordion-{{ block.id }} .pa-answer ol {
    margin: 0;
    padding-left: 20px;
  }

  .pa-accordion-{{ block.id }} .pa-answer li + li {
    margin-top: 6px;
  }

  @media screen and (max-width: 749px) {
    .pa-accordion-{{ block.id }} {
      --pa-title-size: {{ block.settings.ai_acc_title_size_mobile }}px;
      --pa-text-size: {{ block.settings.ai_acc_text_size_mobile }}px;
      --pa-icon-size: {{ block.settings.ai_acc_icon_size_mobile }}px;
      --pa-gap: {{ block.settings.ai_acc_item_gap_mobile }}px;
    }

    .pa-accordion-{{ block.id }} .pa-summary {
      padding: {{ block.settings.ai_acc_padding_y_mobile }}px 0;
      gap: 14px;
    }

    .pa-accordion-{{ block.id }} .pa-arrow {
      width: {{ block.settings.ai_acc_chevron_size_mobile }}px;
      height: {{ block.settings.ai_acc_chevron_size_mobile }}px;
      flex-basis: {{ block.settings.ai_acc_chevron_size_mobile }}px;
    }

    .pa-accordion-{{ block.id }} .pa-answer {
      padding-bottom: {{ block.settings.ai_acc_answer_padding_bottom_mobile }}px;
    }
  }
</style>

<div class="pa-accordion-{{ block.id }}" {{ block.shopify_attributes }}>
  {% for i in (1..5) %}
    {% liquid
      assign enabled_key = 'ai_acc_item_' | append: i | append: '_show'
      assign icon_key = 'ai_acc_item_' | append: i | append: '_icon'
      assign title_key = 'ai_acc_item_' | append: i | append: '_title'
      assign content_key = 'ai_acc_item_' | append: i | append: '_content'

      assign item_enabled = block.settings[enabled_key]
      assign item_icon = block.settings[icon_key]
      assign item_title = block.settings[title_key]
      assign item_content = block.settings[content_key]
    %}

    {% if item_enabled and item_title != blank %}
      <details class="pa-item" {% if block.settings.ai_acc_first_open and forloop.first %}open{% endif %}>
        <summary class="pa-summary">
          <span class="pa-left">
            {% unless item_icon == 'none' %}
              <span class="pa-icon-wrap" aria-hidden="true">
                {% case item_icon %}
                  {% when 'adjustments-horizontal' %}
                    <svg viewBox="0 0 24 24"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
                  {% when 'banknotes' %}
                    <svg viewBox="0 0 24 24"><path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>
                  {% when 'battery-100' %}
                    <svg viewBox="0 0 24 24"><path d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5H18V15H4.5v-4.5ZM3.75 18h15A2.25 2.25 0 0 0 21 15.75v-6a2.25 2.25 0 0 0-2.25-2.25h-15A2.25 2.25 0 0 0 1.5 9.75v6A2.25 2.25 0 0 0 3.75 18Z"/></svg>
                  {% when 'battery-0' %}
                    <svg viewBox="0 0 24 24"><path d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0 0 21 15.75v-6a2.25 2.25 0 0 0-2.25-2.25h-15A2.25 2.25 0 0 0 1.5 9.75v6A2.25 2.25 0 0 0 3.75 18Z"/></svg>
                  {% when 'bell-slash' %}
                    <svg viewBox="0 0 24 24"><path d="M9.143 17.082a24.248 24.248 0 0 0 3.844.148m-3.844-.148a23.856 23.856 0 0 1-5.455-1.31 8.964 8.964 0 0 0 2.3-5.542m3.155 6.852a3 3 0 0 0 5.667 1.97m1.965-2.277L21 21m-4.225-4.225a23.81 23.81 0 0 0 3.536-1.003A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6.53 6.53m10.245 10.245L6.53 6.53M3 3l3.53 3.53"/></svg>
                  {% when 'bell' %}
                    <svg viewBox="0 0 24 24"><path d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>
                  {% when 'book-open' %}
                    <svg viewBox="0 0 24 24"><path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
                  {% when 'calendar' %}
                    <svg viewBox="0 0 24 24"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z"/></svg>
                  {% when 'camera' %}
                    <svg viewBox="0 0 24 24"><path d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z"/><path d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z"/></svg>
                  {% when 'chat-bubble' %}
                    <svg viewBox="0 0 24 24"><path d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/></svg>
                  {% when 'check-badge' %}
                    <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
                  {% when 'clock' %}
                    <svg viewBox="0 0 24 24"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                  {% when 'clipboard' %}
                    <svg viewBox="0 0 24 24"><path d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"/></svg>
                  {% when 'setting' %}
                    <svg viewBox="0 0 24 24"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                  {% when 'rueckgabe' %}
                    <svg viewBox="0 0 24 24"><path d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"/></svg>
                  {% when 'eye' %}
                    <svg viewBox="0 0 24 24"><path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                  {% when 'gift' %}
                    <svg viewBox="0 0 24 24"><path d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
                  {% when 'earth' %}
                    <svg viewBox="0 0 24 24"><path d="m20.893 13.393-1.135-1.135a2.252 2.252 0 0 1-.421-.585l-1.08-2.16a.414.414 0 0 0-.663-.107.827.827 0 0 1-.812.21l-1.273-.363a.89.89 0 0 0-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 0 1-1.81 1.025 1.055 1.055 0 0 1-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 0 1-1.383-2.46l.007-.042a2.25 2.25 0 0 1 .29-.787l.09-.15a2.25 2.25 0 0 1 2.37-1.048l1.178.236a1.125 1.125 0 0 0 1.302-.795l.208-.73a1.125 1.125 0 0 0-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 0 1-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 0 1-1.458-1.137l1.411-2.353a2.25 2.25 0 0 0 .286-.76m11.928 9.869A9 9 0 0 0 8.965 3.525m11.928 9.868A9 9 0 1 1 8.965 3.525"/></svg>
                  {% when 'heart' %}
                    <svg viewBox="0 0 24 24"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
                  {% when 'lock-closed' %}
                    <svg viewBox="0 0 24 24"><path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
                  {% when 'truck' %}
                    <svg viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
                {% endcase %}
              </span>
            {% endunless %}

            <span class="pa-label">{{ item_title }}</span>
          </span>

          <span class="pa-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
          </span>
        </summary>

        <div class="pa-content">
          <div class="pa-content-inner">
            <div class="pa-answer rte">
              {{ item_content }}
            </div>
          </div>
        </div>
      </details>
    {% endif %}
  {% endfor %}
</div>

{% if block.settings.ai_acc_single_open %}
  <script>
    (function() {
      var accordion = document.querySelector('.pa-accordion-{{ block.id }}');
      if (!accordion) return;

      var items = accordion.querySelectorAll('.pa-item');
      items.forEach(function(item) {
        item.addEventListener('toggle', function() {
          if (!item.open) return;
          items.forEach(function(other) {
            if (other !== item) other.open = false;
          });
        });
      });
    })();
  </script>
{% endif %}