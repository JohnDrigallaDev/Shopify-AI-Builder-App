{% liquid
  assign section_id = section.id
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign subtext_color = section.settings.subtext_color
  assign card_bg = section.settings.card_bg
  assign overlay_color = section.settings.overlay_color
  assign accent_color = section.settings.accent_color
  assign border_color = section.settings.border_color
  assign arrow_bg = section.settings.arrow_bg
  assign arrow_color = section.settings.arrow_color
  assign controls_bg = section.settings.controls_bg
  assign controls_icon_color = section.settings.controls_icon_color

  assign section_width = section.settings.section_width
  assign content_max_width = section.settings.content_max_width

  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_horizontal = section.settings.padding_horizontal

  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign subheading_size = section.settings.subheading_size
  assign subheading_size_mobile = section.settings.subheading_size_mobile
  assign title_size = section.settings.title_size
  assign title_size_mobile = section.settings.title_size_mobile

  assign radius = section.settings.radius
  assign border_width = section.settings.border_width
  assign shadow_strength = section.settings.shadow_strength
  assign gap_desktop = section.settings.gap_desktop
  assign gap_mobile = section.settings.gap_mobile

  assign slides_desktop = section.settings.slides_desktop
  assign slides_mobile = section.settings.slides_mobile

  assign show_header = section.settings.show_header
  assign show_titles = section.settings.show_titles
  assign show_ratings = section.settings.show_ratings
  assign show_arrows = section.settings.show_arrows
  assign show_play_button = section.settings.show_play_button
  assign show_sound_button = section.settings.show_sound_button

  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign card_ratio = section.settings.card_ratio
%}

{% capture card_ratio_value %}
  {% case card_ratio %}
    {% when 'portrait' %} 9 / 14
    {% when 'square' %} 1 / 1
    {% when 'landscape' %} 16 / 10
    {% else %} 9 / 14
  {% endcase %}
{% endcapture %}

{% capture card_ratio_value_mobile %}
  {% case section.settings.card_ratio_mobile %}
    {% when 'portrait' %} 9 / 14
    {% when 'square' %} 1 / 1
    {% when 'landscape' %} 16 / 10
    {% else %} 9 / 14
  {% endcase %}
{% endcapture %}

<section
  id="ai-video-slider-{{ section_id }}"
  class="ai-video-slider-section"
  style="
    --avs-bg: {{ bg_color }};
    --avs-text: {{ text_color }};
    --avs-subtext: {{ subtext_color }};
    --avs-card-bg: {{ card_bg }};
    --avs-overlay: {{ overlay_color }};
    --avs-accent: {{ accent_color }};
    --avs-border: {{ border_color }};
    --avs-arrow-bg: {{ arrow_bg }};
    --avs-arrow-color: {{ arrow_color }};
    --avs-controls-bg: {{ controls_bg }};
    --avs-controls-icon: {{ controls_icon_color }};
    --avs-radius: {{ radius }}px;
    --avs-border-width: {{ border_width }}px;
    --avs-shadow: 0 {{ shadow_strength | divided_by: 2.0 }}px {{ shadow_strength | times: 2 }}px rgba(0,0,0,0.14);
    --avs-gap-desktop: {{ gap_desktop }}px;
    --avs-gap-mobile: {{ gap_mobile }}px;
    --avs-heading-size: {{ heading_size }}px;
    --avs-heading-size-mobile: {{ heading_size_mobile }}px;
    --avs-subheading-size: {{ subheading_size }}px;
    --avs-subheading-size-mobile: {{ subheading_size_mobile }}px;
    --avs-title-size: {{ title_size }}px;
    --avs-title-size-mobile: {{ title_size_mobile }}px;
    --avs-overlay-opacity: {{ overlay_opacity }};
    --avs-slides-desktop: {{ slides_desktop }};
    --avs-slides-mobile: {{ slides_mobile }};
    --avs-ratio: {{ card_ratio_value | strip }};
    --avs-ratio-mobile: {{ card_ratio_value_mobile | strip }};
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_horizontal }}px;
    padding-right: {{ padding_horizontal }}px;
    background: var(--avs-bg);
  "
  data-section-id="{{ section_id }}"
>
  <div
    class="ai-video-slider__inner{% if section_width == 'custom' %} ai-video-slider__inner--custom{% endif %}"
    {% if section_width == 'custom' %}
      style="max-width: {{ content_max_width }}px;"
    {% endif %}
  >
    {% if show_header %}
      <div class="ai-video-slider__header">
        {% if section.settings.eyebrow != blank %}
          <p class="ai-video-slider__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="ai-video-slider__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="ai-video-slider__subheading rte">
            {{ section.settings.subheading }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-video-slider__wrap">
      {% if show_arrows %}
        <button class="ai-video-slider__arrow ai-video-slider__arrow--prev" type="button" aria-label="Vorheriges Video">
          <span>&larr;</span>
        </button>
      {% endif %}

      <div class="ai-video-slider__viewport" data-slider-viewport>
        <div class="ai-video-slider__track" data-slider-track>
          {% for block in section.blocks %}
            {% liquid
              assign has_shopify_video = false
              assign has_external_video = false

              if block.settings.video != blank
                assign has_shopify_video = true
              elsif block.settings.video_url != blank
                assign has_external_video = true
              endif
            %}

            <article
              class="ai-video-slider__card"
              {{ block.shopify_attributes }}
              data-slide
            >
              <div class="ai-video-slider__media">
                {% if has_shopify_video %}
                  {{
                    block.settings.video
                    | video_tag:
                      image_size: '900x',
                      autoplay: false,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true,
                      preload: 'metadata',
                      class: 'ai-video-slider__video',
                      data-shopify-video: true
                  }}
                {% elsif has_external_video %}
                  <div class="ai-video-slider__iframe-wrap">
                    {{ block.settings.video_url | external_video_url: autoplay: false, loop: true, muted: true | external_video_tag }}
                  </div>
                {% else %}
                  <div class="ai-video-slider__placeholder">
                    <span>Video hinzufügen</span>
                  </div>
                {% endif %}

                <div class="ai-video-slider__overlay"></div>

                {% if show_play_button or show_sound_button %}
                  <div class="ai-video-slider__controls">
                    {% if show_play_button and has_shopify_video %}
                      <button type="button" class="ai-video-slider__control" data-play-toggle aria-label="Play / Pause">
                        <span class="ai-video-slider__icon ai-video-slider__icon--play">▶</span>
                        <span class="ai-video-slider__icon ai-video-slider__icon--pause" hidden>❚❚</span>
                      </button>
                    {% endif %}

                    {% if show_sound_button and has_shopify_video %}
                      <button type="button" class="ai-video-slider__control" data-mute-toggle aria-label="Ton an / aus">
                        <span class="ai-video-slider__icon ai-video-slider__icon--muted">🔇</span>
                        <span class="ai-video-slider__icon ai-video-slider__icon--unmuted" hidden>🔊</span>
                      </button>
                    {% endif %}
                  </div>
                {% endif %}

                {% if show_titles or show_ratings %}
                  <div class="ai-video-slider__content">
                    {% if show_titles and block.settings.title != blank %}
                      <h3 class="ai-video-slider__title">{{ block.settings.title }}</h3>
                    {% endif %}

                    {% if block.settings.subtitle != blank %}
                      <p class="ai-video-slider__subtitle">{{ block.settings.subtitle }}</p>
                    {% endif %}

                    {% if show_ratings and block.settings.rating > 0 %}
                      <div class="ai-video-slider__rating" aria-label="Bewertung {{ block.settings.rating }} von 5">
                        {% assign rating_full = block.settings.rating | floor %}
                        {% for i in (1..5) %}
                          <span class="ai-video-slider__star{% if i <= rating_full %} is-filled{% endif %}">★</span>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </div>

      {% if show_arrows %}
        <button class="ai-video-slider__arrow ai-video-slider__arrow--next" type="button" aria-label="Nächstes Video">
          <span>&rarr;</span>
        </button>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #ai-video-slider-{{ section_id }} {
    color: var(--avs-text);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__inner {
    width: 100%;
    margin: 0 auto;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__inner:not(.ai-video-slider__inner--custom) {
    max-width: {% if section_width == 'full' %}100%{% else %}1200px{% endif %};
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__header {
    max-width: 760px;
    margin: 0 auto 28px;
    text-align: center;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__eyebrow {
    margin: 0 0 10px;
    color: var(--avs-accent);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__heading {
    margin: 0;
    color: var(--avs-text);
    font-size: var(--avs-heading-size-mobile);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__subheading {
    margin-top: 14px;
    color: var(--avs-subtext);
    font-size: var(--avs-subheading-size-mobile);
    line-height: 1.5;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__wrap {
    position: relative;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__viewport::-webkit-scrollbar {
    display: none;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--avs-gap-mobile) * (var(--avs-slides-mobile) - 1))) / var(--avs-slides-mobile));
    gap: var(--avs-gap-mobile);
    align-items: stretch;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__card {
    scroll-snap-align: start;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__media {
    position: relative;
    aspect-ratio: var(--avs-ratio-mobile);
    border-radius: var(--avs-radius);
    overflow: hidden;
    background: var(--avs-card-bg);
    border: var(--avs-border-width) solid var(--avs-border);
    box-shadow: var(--avs-shadow);
    isolation: isolate;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__video,
  #ai-video-slider-{{ section_id }} .ai-video-slider__iframe-wrap,
  #ai-video-slider-{{ section_id }} .ai-video-slider__iframe-wrap iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__video {
    object-fit: cover;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__iframe-wrap iframe {
    border: 0;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--avs-overlay) calc(var(--avs-overlay-opacity) * 100%), transparent);
    pointer-events: none;
    z-index: 1;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__content {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: 18px;
    background: linear-gradient(to top, rgba(0,0,0,0.52), rgba(0,0,0,0.18), transparent);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__title {
    margin: 0;
    color: #fff;
    font-size: var(--avs-title-size-mobile);
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__subtitle {
    margin: 6px 0 0;
    color: rgba(255,255,255,0.84);
    font-size: 14px;
    line-height: 1.4;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__rating {
    display: flex;
    gap: 4px;
    margin-top: 10px;
    font-size: 14px;
    line-height: 1;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__star {
    color: rgba(255,255,255,0.35);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__star.is-filled {
    color: #fff;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__controls {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    display: flex;
    gap: 8px;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__control {
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 999px;
    background: var(--avs-controls-bg);
    color: var(--avs-controls-icon);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: transform .2s ease, opacity .2s ease;
    box-shadow: 0 8px 18px rgba(0,0,0,0.15);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__control:hover {
    transform: translateY(-1px);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__control:active {
    transform: translateY(0);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 48px;
    height: 48px;
    border: 0;
    border-radius: 999px;
    background: var(--avs-arrow-bg);
    color: var(--avs-arrow-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 10px 22px rgba(0,0,0,0.16);
    transition: transform .2s ease, opacity .2s ease;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__arrow:hover {
    transform: translateY(-50%) scale(1.04);
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__arrow--prev {
    left: -18px;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__arrow--next {
    right: -18px;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__arrow[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
  }

  #ai-video-slider-{{ section_id }} .ai-video-slider__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02)),
      #d9d9d9;
    color: rgba(0,0,0,0.56);
    font-size: 15px;
    font-weight: 600;
  }

  @media screen and (max-width: 767px) {
    #ai-video-slider-{{ section_id }} .ai-video-slider__arrow {
      display: none;
    }
  }

  @media screen and (min-width: 768px) {
    #ai-video-slider-{{ section_id }} .ai-video-slider__heading {
      font-size: var(--avs-heading-size);
    }

    #ai-video-slider-{{ section_id }} .ai-video-slider__subheading {
      font-size: var(--avs-subheading-size);
    }

    #ai-video-slider-{{ section_id }} .ai-video-slider__track {
      grid-auto-columns: calc((100% - (var(--avs-gap-desktop) * (var(--avs-slides-desktop) - 1))) / var(--avs-slides-desktop));
      gap: var(--avs-gap-desktop);
    }

    #ai-video-slider-{{ section_id }} .ai-video-slider__media {
      aspect-ratio: var(--avs-ratio);
    }

    #ai-video-slider-{{ section_id }} .ai-video-slider__title {
      font-size: var(--avs-title-size);
    }

    #ai-video-slider-{{ section_id }} .ai-video-slider__content {
      padding: 20px;
    }
  }
</style>

<script>
  (function() {
    const section = document.getElementById('ai-video-slider-{{ section_id }}');
    if (!section) return;

    const viewport = section.querySelector('[data-slider-viewport]');
    const track = section.querySelector('[data-slider-track]');
    const slides = Array.from(section.querySelectorAll('[data-slide]'));
    const prevBtn = section.querySelector('.ai-video-slider__arrow--prev');
    const nextBtn = section.querySelector('.ai-video-slider__arrow--next');

    if (!viewport || !track || !slides.length) return;

    function getStepWidth() {
      const firstSlide = slides[0];
      if (!firstSlide) return 0;
      const styles = window.getComputedStyle(track);
      const gap = parseFloat(styles.columnGap || styles.gap || 0);
      return firstSlide.getBoundingClientRect().width + gap;
    }

    function updateArrowState() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.disabled = viewport.scrollLeft <= 4;
      nextBtn.disabled = viewport.scrollLeft + viewport.clientWidth >= viewport.scrollWidth - 4;
    }

    function scrollByStep(direction) {
      const step = getStepWidth();
      viewport.scrollBy({
        left: direction * step,
        behavior: 'smooth'
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        scrollByStep(-1);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        scrollByStep(1);
      });
    }

    viewport.addEventListener('scroll', updateArrowState);
    window.addEventListener('resize', updateArrowState);
    updateArrowState();

    slides.forEach((slide) => {
      const video = slide.querySelector('video');
      const playBtn = slide.querySelector('[data-play-toggle]');
      const muteBtn = slide.querySelector('[data-mute-toggle]');

      if (video) {
        video.addEventListener('click', function() {
          if (video.paused) {
            pauseAllVideos(video);
            video.play().catch(() => {});
            setPlayState(slide, true);
          } else {
            video.pause();
            setPlayState(slide, false);
          }
        });

        video.addEventListener('play', function() {
          setPlayState(slide, true);
        });

        video.addEventListener('pause', function() {
          setPlayState(slide, false);
        });

        video.addEventListener('volumechange', function() {
          setMuteState(slide, video.muted);
        });

        setMuteState(slide, true);
        setPlayState(slide, false);
      }

      if (playBtn && video) {
        playBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();

          if (video.paused) {
            pauseAllVideos(video);
            video.play().catch(() => {});
            setPlayState(slide, true);
          } else {
            video.pause();
            setPlayState(slide, false);
          }
        });
      }

      if (muteBtn && video) {
        muteBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          video.muted = !video.muted;
          setMuteState(slide, video.muted);
        });
      }
    });

    function pauseAllVideos(exceptVideo) {
      slides.forEach((slide) => {
        const v = slide.querySelector('video');
        if (v && v !== exceptVideo) {
          v.pause();
          setPlayState(slide, false);
        }
      });
    }

    function setPlayState(slide, isPlaying) {
      const playIcon = slide.querySelector('.ai-video-slider__icon--play');
      const pauseIcon = slide.querySelector('.ai-video-slider__icon--pause');

      if (playIcon) playIcon.hidden = isPlaying;
      if (pauseIcon) pauseIcon.hidden = !isPlaying;
    }

    function setMuteState(slide, isMuted) {
      const mutedIcon = slide.querySelector('.ai-video-slider__icon--muted');
      const unmutedIcon = slide.querySelector('.ai-video-slider__icon--unmuted');

      if (mutedIcon) mutedIcon.hidden = !isMuted;
      if (unmutedIcon) unmutedIcon.hidden = isMuted;
    }
  })();
</script>

{% schema %}
{
  "name": "AI Video Slider",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Header anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SOCIAL PROOF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Warum Kunden unser Produkt lieben"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "<p>Perfekt für UGC, Testimonials, Produkt-Demos oder Creator-Style Video-Cards.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Breite",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Custom Breite",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Videos pro Ansicht Desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "Videos pro Ansicht Mobile",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Abstand Desktop",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Abstand Mobile",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "card_ratio",
      "label": "Format Desktop",
      "default": "portrait",
      "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Quadratisch" },
        { "value": "landscape", "label": "Landscape" }
      ]
    },
    {
      "type": "select",
      "id": "card_ratio_mobile",
      "label": "Format Mobile",
