{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign target_product = section.settings.product | default: product %}
{% assign current_price = target_product.selected_or_first_available_variant.price | money %}
{% assign compare_price = target_product.selected_or_first_available_variant.compare_at_price %}

{% if target_product != blank %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__spotlight">
      <div class="ai-builder-section__spotlight-media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag: loading: 'lazy', widths: '480,720,960,1400', alt: target_product.title
          }}
        {% elsif target_product.featured_image != blank %}
          {{
            target_product.featured_image
            | image_url: width: 1400
            | image_tag: loading: 'lazy', widths: '480,720,960,1400', alt: target_product.title
          }}
        {% else %}
          <div class="ai-builder-section__spotlight-placeholder">
            <span>{{ target_product.title }}</span>
          </div>
        {% endif %}
      </div>

      <div class="ai-builder-section__spotlight-content">
        {% if section.settings.eyebrow != blank %}
          <p class="ai-builder-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="ai-builder-section__title">
          {{ section.settings.heading | default: target_product.title }}
        </h2>
        {% if section.settings.text != blank %}
          <div class="ai-builder-section__body rte">{{ section.settings.text }}</div>
        {% endif %}

        <div class="ai-builder-section__spotlight-price">
          <span class="ai-builder-section__spotlight-price-current">{{ current_price }}</span>
          {% if compare_price %}
            <span class="ai-builder-section__spotlight-price-compare">{{ compare_price | money }}</span>
          {% endif %}
        </div>

        {% if section.blocks.size > 0 %}
          <div class="ai-builder-section__spotlight-metrics">
            {% for block in section.blocks %}
              {% if block.type == 'metric' %}
                <div class="ai-builder-section__spotlight-metric" {{ block.shopify_attributes }}>
                  <strong>{{ block.settings.value }}</strong>
                  <span>{{ block.settings.label }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>

          <ul class="ai-builder-section__spotlight-list">
            {% for block in section.blocks %}
              {% if block.type == 'highlight' and block.settings.text != blank %}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}

        <div class="ai-builder-section__spotlight-cta-row">
          {% if target_product.url != blank %}
            <a class="ai-builder-section__button" href="{{ target_product.url }}">
              {{ section.settings.button_label | default: 'View product' }}
            </a>
          {% endif %}
          {% if section.settings.subtext != blank %}
            <p class="ai-builder-section__spotlight-subtext">{{ section.settings.subtext }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI Product Spotlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produkt"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Override Bild"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Top pick"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lead with one sharp promise, then support it with proof points and friction-reducing reasons to buy now.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View product"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Fast setup. Clear benefit. Low friction."
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Wert",
          "default": "4.8/5"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Average rating"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clear outcome-focused reason to buy"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Product Spotlight",
      "blocks": [
        {
          "type": "metric"
        },
        {
          "type": "metric",
          "settings": {
            "value": "30-day",
            "label": "Guarantee"
          }
        },
        {
          "type": "highlight"
        },
        {
          "type": "highlight",
          "settings": {
            "text": "Reduces the main buying objection"
          }
        }
      ]
    }
  ]
}
{% endschema %}
