{% liquid
  assign sid = section.id

  assign bg_mode = section.settings.bg_mode
  assign bg_color = section.settings.bg_color
  assign bg_gradient = section.settings.bg_gradient
  assign bg_image = section.settings.bg_image

  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_side = section.settings.padding_side

  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign heading_align = section.settings.heading_align

  assign heading_color = section.settings.heading_color
  assign subheading_color = section.settings.subheading_color
  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign subheading_size = section.settings.subheading_size
  assign subheading_size_mobile = section.settings.subheading_size_mobile

  assign media_radius = section.settings.media_radius
  assign media_border_width = section.settings.media_border_width
  assign media_border_color = section.settings.media_border_color
  assign media_shadow_strength = section.settings.media_shadow_strength
  assign media_max_width = section.settings.media_max_width
  assign media_max_width_mobile = section.settings.media_max_width_mobile

  assign item_title_color = section.settings.item_title_color
  assign item_text_color = section.settings.item_text_color
  assign item_icon_color = section.settings.item_icon_color
  assign item_title_size = section.settings.item_title_size
  assign item_title_size_mobile = section.settings.item_title_size_mobile
  assign item_text_size = section.settings.item_text_size
  assign item_text_size_mobile = section.settings.item_text_size_mobile

  assign icon_size = section.settings.icon_size
  assign icon_size_mobile = section.settings.icon_size_mobile

  assign column_gap = section.settings.column_gap
  assign row_gap = section.settings.row_gap
  assign mobile_grid_gap = section.settings.mobile_grid_gap
%}

<section
  id="ai-hero-benefits-{{ sid }}"
  class="ai-hero-benefits-section"
  style="
    --ahb-bg: {{ bg_color }};
    --ahb-heading-color: {{ heading_color }};
    --ahb-subheading-color: {{ subheading_color }};
    --ahb-heading-size: {{ heading_size }}px;
    --ahb-heading-size-mobile: {{ heading_size_mobile }}px;
    --ahb-subheading-size: {{ subheading_size }}px;
    --ahb-subheading-size-mobile: {{ subheading_size_mobile }}px;

    --ahb-media-radius: {{ media_radius }}px;
    --ahb-media-border-width: {{ media_border_width }}px;
    --ahb-media-border-color: {{ media_border_color }};
    --ahb-media-shadow: 0 {{ media_shadow_strength | divided_by: 2.0 }}px {{ media_shadow_strength | times: 2 }}px rgba(0,0,0,0.12);
    --ahb-media-max-width: {{ media_max_width }}px;
    --ahb-media-max-width-mobile: {{ media_max_width_mobile }}px;

    --ahb-item-title-color: {{ item_title_color }};
    --ahb-item-text-color: {{ item_text_color }};
    --ahb-item-icon-color: {{ item_icon_color }};
    --ahb-item-title-size: {{ item_title_size }}px;
    --ahb-item-title-size-mobile: {{ item_title_size_mobile }}px;
    --ahb-item-text-size: {{ item_text_size }}px;
    --ahb-item-text-size-mobile: {{ item_text_size_mobile }}px;
    --ahb-icon-size: {{ icon_size }}px;
    --ahb-icon-size-mobile: {{ icon_size_mobile }}px;

    --ahb-column-gap: {{ column_gap }}px;
    --ahb-row-gap: {{ row_gap }}px;
    --ahb-mobile-grid-gap: {{ mobile_grid_gap }}px;

    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_side }}px;
    padding-right: {{ padding_side }}px;

    {% if bg_image != blank %}
      background-image:
        {% if bg_mode == 'gradient' %}{{ bg_gradient }}, {% endif %}
        url('{{ bg_image | image_url: width: 2200 }}');
      background-size: cover;
      background-position: center;
    {% elsif bg_mode == 'gradient' %}
      background: {{ bg_gradient }};
    {% else %}
      background: {{ bg_color }};
    {% endif %}
  "
>
  <div
    class="ai-hero-benefits__inner{% if section_width == 'custom' %} ai-hero-benefits__inner--custom{% endif %}{% if section_width == 'full' %} ai-hero-benefits__inner--full{% endif %}"
    {% if section_width == 'custom' %}
      style="max-width: {{ custom_width }}px;"
    {% endif %}
  >
    {% if heading != blank or subheading != blank %}
      <div class="ai-hero-benefits__header ai-hero-benefits__header--{{ heading_align }}">
        {% if heading != blank %}
          <h2 class="ai-hero-benefits__heading">{{ heading }}</h2>
        {% endif %}
        {% if subheading != blank %}
          <div class="ai-hero-benefits__subheading">{{ subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% assign hero_block = section.blocks.first %}

    {% if hero_block %}
      <div class="ai-hero-benefits__desktop-layout" {{ hero_block.shopify_attributes }}>
        <div class="ai-hero-benefits__benefits-col ai-hero-benefits__benefits-col--left">
          {% for i in (1..2) %}
            {% liquid
              assign icon_key = 'icon_' | append: i
              assign title_key = 'title_' | append: i
              assign text_key = 'text_' | append: i
              assign image_key = 'image_' | append: i
              assign show_key = 'show_benefit_' | append: i
              assign item_icon = hero_block.settings[icon_key]
              assign item_title = hero_block.settings[title_key]
              assign item_text = hero_block.settings[text_key]
              assign item_image = hero_block.settings[image_key]
              assign show_item = hero_block.settings[show_key]
            %}
            {% if show_item %}
              <div class="ai-hero-benefits__benefit ai-hero-benefits__benefit--left">
                <div class="ai-hero-benefits__benefit-icon-wrap">
                  {% if item_image != blank %}
                    {{
                      item_image
                      | image_url: width: 180
                      | image_tag:
                        class: 'ai-hero-benefits__benefit-icon-image',
                        widths: '60,90,120,180',
                        loading: 'lazy',
                        alt: item_title | escape
                    }}
                  {% else %}
                    <div class="ai-hero-benefits__benefit-icon" aria-hidden="true">
                      {% render 'ai-product-info-icon', icon: item_icon %}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-hero-benefits__benefit-content">
                  {% if item_title != blank %}
                    <h3 class="ai-hero-benefits__benefit-title">{{ item_title }}</h3>
                  {% endif %}
                  {% if item_text != blank %}
                    <div class="ai-hero-benefits__benefit-text">{{ item_text }}</div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="ai-hero-benefits__media-col">
          <div class="ai-hero-benefits__media-frame">
            {% if hero_block.settings.use_video and hero_block.settings.video != blank %}
              {{
                hero_block.settings.video
                | video_tag:
                  image_size: '1400x',
                  autoplay: true,
                  loop: true,
                  controls: false,
                  muted: true,
                  playsinline: true,
                  class: 'ai-hero-benefits__media'
              }}
            {% elsif hero_block.settings.image != blank %}
              {{
                hero_block.settings.image
                | image_url: width: 1600
                | image_tag:
                  class: 'ai-hero-benefits__media',
                  widths: '400,600,800,1000,1200,1400,1600',
                  sizes: '(min-width: 990px) 42vw, 92vw',
                  loading: 'lazy',
                  alt: hero_block.settings.image.alt | escape
              }}
            {% else %}
              <div class="ai-hero-benefits__media-placeholder">Hauptbild hinzufügen</div>
            {% endif %}
          </div>
        </div>

        <div class="ai-hero-benefits__benefits-col ai-hero-benefits__benefits-col--right">
          {% for i in (3..4) %}
            {% liquid
              assign icon_key = 'icon_' | append: i
              assign title_key = 'title_' | append: i
              assign text_key = 'text_' | append: i
              assign image_key = 'image_' | append: i
              assign show_key = 'show_benefit_' | append: i
              assign item_icon = hero_block.settings[icon_key]
              assign item_title = hero_block.settings[title_key]
              assign item_text = hero_block.settings[text_key]
              assign item_image = hero_block.settings[image_key]
              assign show_item = hero_block.settings[show_key]
            %}
            {% if show_item %}
            <div class="ai-hero-benefits__benefit ai-hero-benefits__benefit--right">
              <div class="ai-hero-benefits__benefit-icon-wrap">
                {% if item_image != blank %}
                  {{
                    item_image
                    | image_url: width: 180
                    | image_tag:
                      class: 'ai-hero-benefits__benefit-icon-image',
                      widths: '60,90,120,180',
                      loading: 'lazy',
                      alt: item_title | escape
                  }}
                {% else %}
                  <div class="ai-hero-benefits__benefit-icon" aria-hidden="true">
                    {% render 'ai-product-info-icon', icon: item_icon %}
                  </div>
                {% endif %}
              </div>
              <div class="ai-hero-benefits__benefit-content">
                {% if item_title != blank %}
                  <h3 class="ai-hero-benefits__benefit-title">{{ item_title }}</h3>
                {% endif %}
                {% if item_text != blank %}
                  <div class="ai-hero-benefits__benefit-text">{{ item_text }}</div>
                {% endif %}
              </div>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ai-hero-benefits__mobile-layout" {{ hero_block.shopify_attributes }}>
        <div class="ai-hero-benefits__media-frame ai-hero-benefits__media-frame--mobile">
          {% if hero_block.settings.use_video and hero_block.settings.video != blank %}
            {{
              hero_block.settings.video
              | video_tag:
                image_size: '1400x',
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                playsinline: true,
                class: 'ai-hero-benefits__media'
            }}
          {% elsif hero_block.settings.image != blank %}
            {{
              hero_block.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'ai-hero-benefits__media',
                widths: '400,600,800,1000,1200,1400',
                sizes: '92vw',
                loading: 'lazy',
                alt: hero_block.settings.image.alt | escape
            }}
          {% else %}
            <div class="ai-hero-benefits__media-placeholder">Hauptbild hinzufügen</div>
          {% endif %}
        </div>

        <div class="ai-hero-benefits__mobile-benefits">
          {% for i in (1..4) %}
            {% liquid
              assign icon_key = 'icon_' | append: i
              assign title_key = 'title_' | append: i
              assign text_key = 'text_' | append: i
              assign image_key = 'image_' | append: i
              assign show_key = 'show_benefit_' | append: i
              assign item_icon = hero_block.settings[icon_key]
              assign item_title = hero_block.settings[title_key]
              assign item_text = hero_block.settings[text_key]
              assign item_image = hero_block.settings[image_key]
              assign show_item = hero_block.settings[show_key]
            %}
            {% if show_item %}
            <div class="ai-hero-benefits__benefit ai-hero-benefits__benefit--mobile">
              <div class="ai-hero-benefits__benefit-icon-wrap">
                {% if item_image != blank %}
                  {{
                    item_image
                    | image_url: width: 180
                    | image_tag:
                      class: 'ai-hero-benefits__benefit-icon-image',
                      widths: '60,90,120,180',
                      loading: 'lazy',
                      alt: item_title | escape
                  }}
                {% else %}
                  <div class="ai-hero-benefits__benefit-icon" aria-hidden="true">
                    {% render 'ai-product-info-icon', icon: item_icon %}
                  </div>
                {% endif %}
              </div>
              <div class="ai-hero-benefits__benefit-content">
                {% if item_title != blank %}
                  <h3 class="ai-hero-benefits__benefit-title">{{ item_title }}</h3>
                {% endif %}
                {% if item_text != blank %}
                  <div class="ai-hero-benefits__benefit-text">{{ item_text }}</div>
                {% endif %}
              </div>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__inner--full {
    max-width: 100%;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__header {
    margin-bottom: 28px;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__header--left {
    text-align: left;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__header--center {
    text-align: center;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__header--right {
    text-align: right;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__heading {
    margin: 0;
    color: var(--ahb-heading-color);
    font-size: var(--ahb-heading-size-mobile);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__subheading {
    margin-top: 10px;
    color: var(--ahb-subheading-color);
    font-size: var(--ahb-subheading-size-mobile);
    line-height: 1.5;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__subheading p {
    margin: 0;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__desktop-layout {
    display: none;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__mobile-layout {
    display: block;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__media-frame {
    width: 100%;
    max-width: var(--ahb-media-max-width-mobile);
    margin: 0 auto;
    overflow: hidden;
    border-radius: var(--ahb-media-radius);
    border: var(--ahb-media-border-width) solid var(--ahb-media-border-color);
    box-shadow: var(--ahb-media-shadow);
    background: rgba(255,255,255,0.04);
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__media,
  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__media video {
    width: 100%;
    height: auto;
    display: block;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__media-placeholder {
    aspect-ratio: 4 / 4.6;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__mobile-benefits {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--ahb-mobile-grid-gap);
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefits-col {
    display: grid;
    gap: var(--ahb-row-gap);
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon {
    width: var(--ahb-icon-size-mobile);
    height: var(--ahb-icon-size-mobile);
    color: var(--ahb-item-icon-color);
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon-image {
    width: var(--ahb-icon-size-mobile);
    height: var(--ahb-icon-size-mobile);
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon svg,
  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon-image {
    max-width: 100%;
    max-height: 100%;
    display: block;
    object-fit: contain;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon svg {
    width: 100%;
    height: 100%;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-title {
    margin: 0;
    color: var(--ahb-item-title-color);
    font-size: var(--ahb-item-title-size-mobile);
    line-height: 1.15;
    font-weight: 600;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-text {
    margin-top: 4px;
    color: var(--ahb-item-text-color);
    font-size: var(--ahb-item-text-size-mobile);
    line-height: 1.45;
  }

  #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-text p {
    margin: 0;
  }

  @media screen and (min-width: 990px) {
    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__heading {
      font-size: var(--ahb-heading-size);
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__subheading {
      font-size: var(--ahb-subheading-size);
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__desktop-layout {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) minmax(420px, var(--ahb-media-max-width)) minmax(180px, 1fr);
      gap: var(--ahb-column-gap);
      align-items: center;
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__mobile-layout {
      display: none;
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__media-frame {
      max-width: var(--ahb-media-max-width);
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit {
      min-height: 160px;
      justify-content: center;
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon,
    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-icon-image {
      width: var(--ahb-icon-size);
      height: var(--ahb-icon-size);
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-title {
      font-size: var(--ahb-item-title-size);
    }

    #ai-hero-benefits-{{ sid }} .ai-hero-benefits__benefit-text {
      font-size: var(--ahb-item-text-size);
    }
  }
</style>

{% schema %}
{
  "name": "AI Hero Benefits",
  "tag": "section",
  "class": "section",
  "max_blocks": 1,
  "settings": [
    {
      "type": "header",
      "content": "Section Hintergrund"
    },
    {
      "type": "select",
      "id": "bg_mode",
      "label": "Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Hintergrundbild optional"
    },

    {
      "type": "header",
      "content": "Breite"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Breite",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Breite",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1400
    },

    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "A hero section headline"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Untertitel",
      "default": "<p>Add a short supporting sentence here.</p>"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Header Ausrichtung",
      "default": "center",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ]
    },

    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },

    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "range",
      "id": "media_max_width",
      "label": "Bildbreite Desktop",
      "min": 320,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "media_max_width_mobile",
      "label": "Bildbreite Mobile",
      "min": 220,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Bild Radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "media_border_width",
      "label": "Bild Border",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "media_shadow_strength",
      "label": "Bild Shadow",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "Benefit Layout"
    },
    {
      "type": "range",
