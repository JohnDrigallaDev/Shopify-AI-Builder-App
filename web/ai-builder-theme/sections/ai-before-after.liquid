{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign ai_page = product.metafields.ai_builder.page_json.value %}
{% assign ai_section = blank %}

{% if ai_page and ai_page.sections %}
  {% for page_section in ai_page.sections %}
    {% if page_section.type == 'before_after' %}
      {% assign ai_section = page_section %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker %}
{% assign title = section.settings.title | strip | default: ai_section.title %}
{% assign before_label = section.settings.before_label | strip | default: ai_section.beforeLabel %}
{% assign before_text = section.settings.before_text | strip | default: ai_section.beforeText %}
{% assign after_label = section.settings.after_label | strip | default: ai_section.afterLabel %}
{% assign after_text = section.settings.after_text | strip | default: ai_section.afterText %}

{% if eyebrow != blank or title != blank or before_text != blank or after_text != blank %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__panel">
      {% if eyebrow != blank %}
        <p class="ai-builder-section__eyebrow">{{ eyebrow }}</p>
      {% endif %}
      {% if title != blank %}
        <h2 class="ai-builder-section__title">{{ title }}</h2>
      {% endif %}
      <div class="ai-builder-section__before-after">
        <div class="ai-builder-section__before-after-card">
          <p class="ai-builder-section__label">{{ before_label | default: 'Vorher' }}</p>
          <div class="ai-builder-section__body rte">{{ before_text | newline_to_br }}</div>
        </div>
        <div class="ai-builder-section__before-after-card ai-builder-section__before-after-card--accent">
          <p class="ai-builder-section__label">{{ after_label | default: 'Nachher' }}</p>
          <div class="ai-builder-section__body rte">{{ after_text | newline_to_br }}</div>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI Before After",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Vorher Label"
    },
    {
      "type": "richtext",
      "id": "before_text",
      "label": "Vorher Text"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Nachher Label"
    },
    {
      "type": "richtext",
      "id": "after_text",
      "label": "Nachher Text"
    }
  ],
  "presets": [
    {
      "name": "AI Before After"
    }
  ]
}
{% endschema %}
