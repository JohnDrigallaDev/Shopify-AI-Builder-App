{% liquid
  assign ai_load = 'eager'
  if section.settings.ai_lazy
    assign ai_load = 'lazy'
  endif
%}

<style>
  {{ section.settings.ai_heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.ai_sub_font | font_face: font_display: 'swap' }}
  {{ section.settings.ai_text_font | font_face: font_display: 'swap' }}
  {{ section.settings.ai_author_font | font_face: font_display: 'swap' }}

  #pai-testimonials-{{ section.id }} {
    margin-top: {{ section.settings.ai_margin_top }}px;
    margin-bottom: {{ section.settings.ai_margin_bottom }}px;
    border-top: {{ section.settings.ai_border_width }}px solid {{ section.settings.ai_border_color }};
    border-bottom: {{ section.settings.ai_border_width }}px solid {{ section.settings.ai_border_color }};
    background-color: {{ section.settings.ai_section_bg }};
    background-image: {{ section.settings.ai_section_gradient }};
    overflow: hidden;
  }

  #pai-testimonials-{{ section.id }} .pai-wrap {
    max-width: {% if section.settings.ai_full_width %}none{% else %}{{ section.settings.ai_content_width }}px{% endif %};
    margin: 0 auto;
    padding: {{ section.settings.ai_padding_top }}px {{ section.settings.ai_padding_x_mobile }}rem {{ section.settings.ai_padding_bottom }}px;
  }

  #pai-testimonials-{{ section.id }} .pai-heading {
    text-align: {{ section.settings.ai_heading_align_mobile }};
  }

  #pai-testimonials-{{ section.id }} .pai-heading * {
    margin: 0;
    color: {{ section.settings.ai_heading_color }};
    font-size: {{ section.settings.ai_heading_size_mobile }}px;
    line-height: {{ section.settings.ai_heading_line }}%;
    {% if section.settings.ai_heading_custom %}
      font-family: {{ section.settings.ai_heading_font.family }}, {{ section.settings.ai_heading_font.fallback_families }};
      font-weight: {{ section.settings.ai_heading_font.weight }};
      font-style: {{ section.settings.ai_heading_font.style }};
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-subheading {
    margin-top: {{ section.settings.ai_sub_mt }}px;
    text-align: {{ section.settings.ai_sub_align_mobile }};
  }

  #pai-testimonials-{{ section.id }} .pai-subheading * {
    margin: 0;
    color: {{ section.settings.ai_sub_color }};
    font-size: {{ section.settings.ai_sub_size_mobile }}px;
    line-height: {{ section.settings.ai_sub_line }}%;
    {% if section.settings.ai_sub_custom %}
      font-family: {{ section.settings.ai_sub_font.family }}, {{ section.settings.ai_sub_font.fallback_families }};
      font-weight: {{ section.settings.ai_sub_font.weight }};
      font-style: {{ section.settings.ai_sub_font.style }};
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-stage {
    margin-top: {{ section.settings.ai_slider_mt }}px;
    overflow: hidden;
    cursor: grab;
  }

  #pai-testimonials-{{ section.id }} .pai-stage.is-dragging {
    cursor: grabbing;
  }

  #pai-testimonials-{{ section.id }} .pai-track {
    display: flex;
    gap: {{ section.settings.ai_gap_mobile }}px;
    transition: transform 320ms ease;
    will-change: transform;
  }

  #pai-testimonials-{{ section.id }} .pai-card {
    flex: 0 0 calc((100% - ({{ section.settings.ai_gap_mobile }}px * ({{ section.settings.ai_view_mobile }} - 1))) / {{ section.settings.ai_view_mobile }});
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: {{ section.settings.ai_card_py_mobile }}px {{ section.settings.ai_card_px_mobile }}px;
    border-radius: {{ section.settings.ai_card_radius }}px;
    border: {{ section.settings.ai_card_border }}px solid {{ section.settings.ai_card_border_color }};
    background-color: {{ section.settings.ai_card_bg }};
    background-image: {{ section.settings.ai_card_gradient }};
    box-sizing: border-box;
    overflow: hidden;
    {% if section.settings.ai_card_shadow %}
      box-shadow: 0 8px 24px rgba(0,0,0,.08);
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-media {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.ai_media_radius }}px;
    border: {{ section.settings.ai_media_border }}px solid {{ section.settings.ai_media_border_color }};
    {% if section.settings.ai_media_ratio_mobile == 'portrait' %}
      aspect-ratio: 9.6 / 12;
    {% elsif section.settings.ai_media_ratio_mobile == 'big_portrait' %}
      aspect-ratio: 9.6 / 16;
    {% elsif section.settings.ai_media_ratio_mobile == 'landscape' %}
      aspect-ratio: 12 / 9;
    {% elsif section.settings.ai_media_ratio_mobile == 'square' %}
      aspect-ratio: 1 / 1;
    {% else %}
      aspect-ratio: auto;
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-media img,
  #pai-testimonials-{{ section.id }} .pai-media svg,
  #pai-testimonials-{{ section.id }} .pai-media video,
  #pai-testimonials-{{ section.id }} .pai-media iframe {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border: 0;
  }

  #pai-testimonials-{{ section.id }} .pai-play {
    position: absolute;
    z-index: 3;
    left: 50%;
    top: 50%;
    width: {{ section.settings.ai_play_size_mobile }}px;
    height: {{ section.settings.ai_play_size_mobile }}px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    border: 0;
    background: {{ section.settings.ai_play_bg }};
    color: {{ section.settings.ai_play_color }};
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: opacity .2s ease, transform .2s ease;
  }

  #pai-testimonials-{{ section.id }} .pai-play svg {
    width: 45%;
    height: 45%;
    fill: currentColor;
    margin-left: 3px;
  }

  #pai-testimonials-{{ section.id }} .pai-play.is-playing {
    opacity: 0;
    pointer-events: none;
  }

  #pai-testimonials-{{ section.id }} .pai-content {
    padding: {{ section.settings.ai_content_py_mobile }}px {{ section.settings.ai_content_px_mobile }}px;
    flex: 1 1 auto;
  }

  #pai-testimonials-{{ section.id }} .pai-stars {
    margin-top: {{ section.settings.ai_stars_mt }}px;
    display: flex;
    gap: 2px;
    justify-content: {{ section.settings.ai_stars_align_mobile }};
  }

  #pai-testimonials-{{ section.id }} .pai-stars svg,
  #pai-testimonials-{{ section.id }} .pai-stars img {
    width: {{ section.settings.ai_stars_size }}px;
    height: {{ section.settings.ai_stars_size }}px;
    display: block;
  }

  #pai-testimonials-{{ section.id }} .pai-text {
    margin-top: {{ section.settings.ai_text_mt }}px;
    text-align: {{ section.settings.ai_text_align_mobile }};
  }

  #pai-testimonials-{{ section.id }} .pai-text * {
    margin: 0;
    color: {{ section.settings.ai_text_color }};
    font-size: {{ section.settings.ai_text_size_mobile }}px;
    line-height: {{ section.settings.ai_text_line }}%;
    {% if section.settings.ai_text_custom %}
      font-family: {{ section.settings.ai_text_font.family }}, {{ section.settings.ai_text_font.fallback_families }};
      font-weight: {{ section.settings.ai_text_font.weight }};
      font-style: {{ section.settings.ai_text_font.style }};
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-author {
    margin-top: {{ section.settings.ai_author_mt }}px;
    text-align: {{ section.settings.ai_author_align_mobile }};
  }

  #pai-testimonials-{{ section.id }} .pai-author * {
    margin: 0;
    color: {{ section.settings.ai_author_color }};
    font-size: {{ section.settings.ai_author_size_mobile }}px;
    line-height: {{ section.settings.ai_author_line }}%;
    {% if section.settings.ai_author_custom %}
      font-family: {{ section.settings.ai_author_font.family }}, {{ section.settings.ai_author_font.fallback_families }};
      font-weight: {{ section.settings.ai_author_font.weight }};
      font-style: {{ section.settings.ai_author_font.style }};
    {% endif %}
  }

  #pai-testimonials-{{ section.id }} .pai-nav {
    margin-top: {{ section.settings.ai_nav_mt }}px;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.ai_nav_align_mobile }};
    gap: {{ section.settings.ai_nav_gap }}px;
  }

  #pai-testimonials-{{ section.id }} .pai-arrow {
    width: {{ section.settings.ai_arrow_size_mobile }}px;
    height: {{ section.settings.ai_arrow_size_mobile | times: 0.45 | round }}px;
    border: 0;
    background: transparent;
    color: {{ section.settings.ai_arrow_color }};
    padding: 0;
    cursor: pointer;
    display: {% if section.settings.ai_arrows_mobile %}flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
  }

  #pai-testimonials-{{ section.id }} .pai-arrow:hover {
    color: {{ section.settings.ai_arrow_hover }};
  }

  #pai-testimonials-{{ section.id }} .pai-arrow svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }

  #pai-testimonials-{{ section.id }} .pai-dots {
    display: {% if section.settings.ai_dots_mobile %}flex{% else %}none{% endif %};
    align-items: center;
    gap: 6px;
  }

  #pai-testimonials-{{ section.id }} .pai-dot {
    width: {{ section.settings.ai_dot_size_mobile }}px;
    height: {{ section.settings.ai_dot_size_mobile }}px;
    border-radius: 999px;
    border: 1px solid {{ section.settings.ai_dots_color }};
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  #pai-testimonials-{{ section.id }} .pai-dot.is-active {
    background: {{ section.settings.ai_dots_color }};
  }

  @media screen and (min-width: 1024px) {
    #pai-testimonials-{{ section.id }} .pai-wrap {
      padding-left: {{ section.settings.ai_padding_x }}rem;
      padding-right: {{ section.settings.ai_padding_x }}rem;
    }

    #pai-testimonials-{{ section.id }} .pai-heading {
      text-align: {{ section.settings.ai_heading_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-heading * {
      font-size: {{ section.settings.ai_heading_size }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-subheading {
      text-align: {{ section.settings.ai_sub_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-subheading * {
      font-size: {{ section.settings.ai_sub_size }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-track {
      gap: {{ section.settings.ai_gap }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-card {
      flex-basis: calc((100% - ({{ section.settings.ai_gap }}px * ({{ section.settings.ai_view }} - 1))) / {{ section.settings.ai_view }});
      padding: {{ section.settings.ai_card_py }}px {{ section.settings.ai_card_px }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-media {
      {% if section.settings.ai_media_ratio == 'portrait' %}
        aspect-ratio: 9.6 / 12;
      {% elsif section.settings.ai_media_ratio == 'big_portrait' %}
        aspect-ratio: 9.6 / 16;
      {% elsif section.settings.ai_media_ratio == 'landscape' %}
        aspect-ratio: 12 / 9;
      {% elsif section.settings.ai_media_ratio == 'square' %}
        aspect-ratio: 1 / 1;
      {% else %}
        aspect-ratio: auto;
      {% endif %}
    }

    #pai-testimonials-{{ section.id }} .pai-play {
      width: {{ section.settings.ai_play_size }}px;
      height: {{ section.settings.ai_play_size }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-content {
      padding: {{ section.settings.ai_content_py }}px {{ section.settings.ai_content_px }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-stars {
      justify-content: {{ section.settings.ai_stars_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-text {
      text-align: {{ section.settings.ai_text_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-text * {
      font-size: {{ section.settings.ai_text_size }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-author {
      text-align: {{ section.settings.ai_author_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-author * {
      font-size: {{ section.settings.ai_author_size }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-nav {
      justify-content: {{ section.settings.ai_nav_align }};
    }

    #pai-testimonials-{{ section.id }} .pai-arrow {
      display: {% if section.settings.ai_arrows_desktop %}flex{% else %}none{% endif %};
      width: {{ section.settings.ai_arrow_size }}px;
      height: {{ section.settings.ai_arrow_size | times: 0.45 | round }}px;
    }

    #pai-testimonials-{{ section.id }} .pai-dots {
      display: {% if section.settings.ai_dots_desktop %}flex{% else %}none{% endif %};
    }

    #pai-testimonials-{{ section.id }} .pai-dot {
      width: {{ section.settings.ai_dot_size }}px;
      height: {{ section.settings.ai_dot_size }}px;
    }
  }
</style>

<section id="pai-testimonials-{{ section.id }}">
  <div class="pai-wrap">
    {% if section.settings.ai_heading != blank %}
      <div class="pai-heading">{{ section.settings.ai_heading }}</div>
    {% endif %}

    {% if section.settings.ai_subheading != blank %}
      <div class="pai-subheading">{{ section.settings.ai_subheading }}</div>
    {% endif %}

    <div class="pai-stage" data-pai-stage>
      <div class="pai-track" data-pai-track>
        {% for block in section.blocks %}
          <article class="pai-card" data-pai-card {{ block.shopify_attributes }}>
            {% unless block.settings.ai_media_type == 'none' %}
              <div class="pai-media">
                {% if block.settings.ai_media_type == 'image' %}
                  {% if block.settings.ai_image != blank %}
                    {{ block.settings.ai_image | image_url: width: 1200 | image_tag: loading: ai_load, alt: block.settings.ai_image.alt }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
                {% elsif block.settings.ai_media_type == 'video' %}
                  {% if block.settings.ai_poster != blank %}
                    <div class="pai-poster" data-pai-poster>
                      {{ block.settings.ai_poster | image_url: width: 1200 | image_tag: loading: ai_load, alt: block.settings.ai_poster.alt }}
                    </div>
                  {% endif %}

                  {% if block.settings.ai_video != blank %}
                    {{
                      block.settings.ai_video
                      | video_tag:
                        controls: block.settings.ai_controls,
                        loop: true,
                        muted: false,
                        playsinline: true,
                        preload: 'metadata'
                    }}
                  {% elsif block.settings.ai_video_url != blank %}
                    {% assign embed_id = block.settings.ai_video_url.id %}
                    {% if block.settings.ai_video_url.type == 'youtube' %}
                      <iframe
                        data-pai-embed
                        src="https://www.youtube.com/embed/{{ embed_id }}?rel=0&playsinline=1"
                        loading="{{ ai_load }}"
                        allow="autoplay; encrypted-media; picture-in-picture"
                        allowfullscreen>
                      </iframe>
                    {% elsif block.settings.ai_video_url.type == 'vimeo' %}
                      <iframe
                        data-pai-embed
                        src="https://player.vimeo.com/video/{{ embed_id }}"
                        loading="{{ ai_load }}"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen>
                      </iframe>
                    {% endif %}
                  {% else %}
                    <video loop playsinline preload="metadata">
                      <source src="https://cdn.shopify.com/videos/c/o/v/fbb140fd46e3429eba459e1549dbbe38.mp4" type="video/mp4">
                    </video>
                  {% endif %}

                  <button class="pai-play" type="button" aria-label="Video abspielen" data-pai-play>
                    {% if section.settings.ai_play_icon != blank %}
                      {{ section.settings.ai_play_icon | image_url: width: 200 | image_tag: loading: 'lazy' }}
                    {% else %}
                      <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    {% endif %}
                  </button>
                {% endif %}
              </div>
            {% endunless %}

            {% unless section.settings.ai_hide_content %}
              <div class="pai-content">
                {% if block.settings.ai_rating > 0 %}
                  <div class="pai-stars">
                    {% assign full_rating = block.settings.ai_rating | floor %}
                    {% assign decimal_rating = block.settings.ai_rating | minus: full_rating %}
                    {% assign next_star = full_rating | plus: 1 %}
                    {% for star in (1..5) %}
                      {% if section.settings.ai_stars_icon != blank %}
                        {% if star <= block.settings.ai_rating %}
                          {{ section.settings.ai_stars_icon | image_url: width: 80 | image_tag: loading: 'lazy' }}
                        {% endif %}
                      {% else %}
                        {% assign fill_percent = 0 %}
                        {% if star <= full_rating %}
                          {% assign fill_percent = 100 %}
                        {% elsif star == next_star %}
                          {% assign fill_percent = decimal_rating | times: 100 %}
                        {% endif %}
                        <svg viewBox="0 0 24 24">
                          <defs>
                            <linearGradient id="pai-star-{{ section.id }}-{{ block.id }}-{{ star }}">
                              <stop offset="{{ fill_percent }}%" stop-color="{{ section.settings.ai_stars_color }}"></stop>
                              <stop offset="{{ fill_percent }}%" stop-color="transparent"></stop>
                            </linearGradient>
                          </defs>
                          <path d="M12 2.4 15 8.6l6.8 1-4.9 4.8 1.2 6.8L12 18l-6.1 3.2 1.2-6.8-4.9-4.8 6.8-1L12 2.4Z"
                            fill="url(#pai-star-{{ section.id }}-{{ block.id }}-{{ star }})"
                            stroke="{{ section.settings.ai_stars_color }}"
                            stroke-width="1.4"/>
                        </svg>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}

                {% if block.settings.ai_text != blank %}
                  <div class="pai-text">{{ block.settings.ai_text }}</div>
                {% endif %}

                {% if block.settings.ai_author != blank %}
                  <div class="pai-author">{{ block.settings.ai_author }}</div>
                {% endif %}
              </div>
            {% endunless %}
          </article>
        {% endfor %}
      </div>
    </div>

    <div class="pai-nav">
      <button class="pai-arrow" type="button" aria-label="Vorherige Bewertung" data-pai-prev>
        <svg viewBox="0 0 92 38" fill="none">
          <path d="M19 19H88M19 19L36 3M19 19L36 35" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="pai-dots" data-pai-dots></div>

      <button class="pai-arrow" type="button" aria-label="Nächste Bewertung" data-pai-next>
        <svg viewBox="0 0 92 38" fill="none">
          <path d="M73 19H4M73 19L56 3M73 19L56 35" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
(() => {
  const root = document.querySelector('#pai-testimonials-{{ section.id }}');
  if (!root) return;

  const stage = root.querySelector('[data-pai-stage]');
  const track = root.querySelector('[data-pai-track]');
  const cards = Array.from(root.querySelectorAll('[data-pai-card]'));
  const prev = root.querySelector('[data-pai-prev]');
  const next = root.querySelector('[data-pai-next]');
  const dotsWrap = root.querySelector('[data-pai-dots]');

  let current = 0;
  let step = 0;
  let startX = 0;
  let moveX = 0;
  let dragging = false;
  let timer = null;

  function viewCount() {
    return window.innerWidth >= 1024
      ? Number({{ section.settings.ai_view }})
      : Number({{ section.settings.ai_view_mobile }});
  }

  function gapSize() {
    return window.innerWidth >= 1024
      ? Number({{ section.settings.ai_gap }})
      : Number({{ section.settings.ai_gap_mobile }});
  }

  function maxIndex() {
    return Math.max(0, cards.length - Math.ceil(viewCount()));
  }

  function measure() {
    if (!cards.length) return;
    step = cards[0].getBoundingClientRect().width + gapSize();
  }

  function pauseMedia() {
    cards.forEach(card => {
      const video = card.querySelector('video');
      const iframe = card.querySelector('iframe');
      const play = card.querySelector('[data-pai-play]');
      const poster = card.querySelector('[data-pai-poster]');

      if (video) video.pause();
      if (iframe) {
        iframe.src = iframe.src.replace('&autoplay=1', '').replace('?autoplay=1&', '?');
      }
      if (play) play.classList.remove('is-playing');
      if (poster) poster.style.display = '';
    });
  }

  function renderDots() {
    if (!dotsWrap) return;
    dotsWrap.innerHTML = '';
    const total = maxIndex() + 1;

    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'pai-dot' + (i === current ? ' is-active' : '');
      dot.setAttribute('aria-label', `Gehe zu Slide ${i + 1}`);
      dot.addEventListener('click', () => {
        current = i;
        update();
        restartAutoplay();
      });
      dotsWrap.appendChild(dot);
    }
  }

  function update() {
    measure();
    current = Math.max(0, Math.min(current, maxIndex()));
    track.style.transform = `translate3d(${-current * step}px, 0, 0)`;

    root.querySelectorAll('.pai-dot').forEach((dot, i) => {
      dot.classList.toggle('is-active', i === current);
    });

    pauseMedia();
  }

  function move(dir) {
    current += dir;
    if (current > maxIndex()) current = 0;
    if (current < 0) current = maxIndex();
    update();
    restartAutoplay();
  }

  if (prev) prev.addEventListener('click', () => move(-1));
  if (next) next.addEventListener('click', () => move(1));

  stage.addEventListener('pointerdown', e => {
    dragging = true;
    startX = e.clientX;
    moveX = startX;
    stage.classList.add('is-dragging');
    track.style.transition = 'none';
    if (stage.setPointerCapture) {
      stage.setPointerCapture(e.pointerId);
    }
    stopAutoplay();
  });

  stage.addEventListener('pointermove', e => {
    if (!dragging) return;
    moveX = e.clientX;
    const delta = moveX - startX;
    track.style.transform = `translate3d(${(-current * step) + delta}px, 0, 0)`;
  });

  function endDrag() {
    if (!dragging) return;
    dragging = false;
    stage.classList.remove('is-dragging');
    track.style.transition = 'transform 320ms ease';

    const delta = moveX - startX;
    if (Math.abs(delta) > 45) {
      if (delta < 0) move(1);
      else move(-1);
    } else {
      update();
    }

    restartAutoplay();
  }

  stage.addEventListener('pointerup', endDrag);
  stage.addEventListener('pointercancel', endDrag);
  stage.addEventListener('pointerleave', endDrag);

  root.querySelectorAll('[data-pai-play]').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      pauseMedia();

      const card = btn.closest('[data-pai-card]');
      const video = card.querySelector('video');
      const iframe = card.querySelector('iframe');
      const poster = card.querySelector('[data-pai-poster]');

      btn.classList.add('is-playing');
      if (poster) poster.style.display = 'none';

      if (video) {
        video.play().catch(() => {});
      }

      if (iframe && !iframe.src.includes('autoplay=1')) {
        iframe.src += iframe.src.includes('?') ? '&autoplay=1' : '?autoplay=1';
      }
    });
  });

  function stopAutoplay() {
    if (timer) clearInterval(timer);
    timer = null;
  }

  function restartAutoplay() {
    stopAutoplay();
    {% if section.settings.ai_autoplay %}
      timer = setInterval(() => move(1), {{ section.settings.ai_autoplay_delay | times: 1000 }});
    {% endif %}
  }

  window.addEventListener('resize', () => {
    renderDots();
    update();
  });

  renderDots();
  update();
  restartAutoplay();
})();
</script>

