{% render 'shared-ai-trust-badges',
  source: section,
  source_type: 'section',
  render_id: 'ai-trust-badges-' | append: section.id
%}

{% schema %}
{
  "name": "AI Trust Badges",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "max_width_mode",
      "label": "Breite",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "max_width_custom",
      "label": "Custom Breite",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Spalten Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Spalten Mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "label": "Abstand Desktop",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "label": "Abstand Mobile",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "label": "Padding oben/unten",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "label": "Padding links/rechts",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Border Breite",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_shadow_strength",
      "label": "Shadow Stärke",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Untere feine Linie anzeigen",
      "default": false
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Linienhöhe",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Größe Desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon Größe Mobile",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Titel Desktop",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Titel Mobile",
      "min": 14,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text Desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Text Mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "section_top",
      "label": "Padding oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "section_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "section_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "section_style_mode",
      "label": "Section Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "outer_bg",
      "label": "Section Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "outer_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8F6F2 100%)"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Hintergrund",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Titel Farbe",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Farbe",
      "default": "#2b2b2b"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Farbe",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Farbe",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Free Shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>over €99 in DE</p>"
        },
        {
          "type": "select",
          "id": "icon_style",
          "label": "Standard Icon",
          "default": "box",
          "options": [
            { "value": "adjustments-horizontal", "label": "Anpassung" },
            { "value": "alarm-clock", "label": "Alarm Clock" },
            { "value": "alert-circle", "label": "Alert Circle" },
            { "value": "alert-triangle", "label": "Alert Triangle" },
            { "value": "annotation-dots", "label": "Annotation Dots" },
            { "value": "announcement", "label": "Announcement" },
            { "value": "arrow-up", "label": "Arrow Up" },
            { "value": "award", "label": "Award" },
            { "value": "banknotes", "label": "Geld" },
            { "value": "battery-100", "label": "Batterie voll" },
            { "value": "battery-0", "label": "Batterie leer" },
            { "value": "bell-slash", "label": "Benachrichtigung aus" },
            { "value": "bell", "label": "Benachrichtigung" },
            { "value": "book", "label": "Book" },
            { "value": "book-open", "label": "Book Open" },
            { "value": "box", "label": "Paket" },
            { "value": "brush", "label": "Brush" },
            { "value": "calendar", "label": "Kalender" },
            { "value": "camera", "label": "Kamera" },
            { "value": "chat-bubble", "label": "Chat" },
            { "value": "check", "label": "Check" },
            { "value": "check-badge", "label": "Check Badge" },
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "check-verified", "label": "Check Verified" },
            { "value": "clock", "label": "Uhr" },
            { "value": "clock-snooze", "label": "Clock Snooze" },
            { "value": "clipboard", "label": "Clipboard" },
            { "value": "credit-card", "label": "Credit Card" },
            { "value": "credit-card-lock", "label": "Credit Card Lock" },
            { "value": "discount-tag", "label": "Discount Tag" },
            { "value": "drop", "label": "Drop" },
            { "value": "earth", "label": "Welt" },
            { "value": "eye", "label": "Auge" },
            { "value": "face-happy", "label": "Face Happy" },
            { "value": "face-sad", "label": "Face Sad" },
            { "value": "face-smile", "label": "Face Smile" },
            { "value": "gift", "label": "Geschenk" },
            { "value": "hand-heart", "label": "Hand + Herz" },
            { "value": "heart", "label": "Herz" },
            { "value": "info-circle", "label": "Info Circle" },
            { "value": "klarna", "label": "K Style" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "lock-closed", "label": "Schloss" },
            { "value": "mail", "label": "Mail" },
            { "value": "map", "label": "Map" },
            { "value": "marker-pin", "label": "Marker Pin" },
            { "value": "medaille", "label": "Medaille" },
            { "value": "moon", "label": "Moon" },
            { "value": "plane", "label": "Plane" },
            { "value": "rueckgabe", "label": "Rückgabe" },
            { "value": "sale", "label": "Sale" },
            { "value": "scoop", "label": "Scoop" },
            { "value": "screen-off", "label": "Screen Off" },
            { "value": "setting", "label": "Einstellung" },
            { "value": "shield", "label": "Shield" },
            { "value": "shopping-cart", "label": "Shopping Cart" },
            { "value": "spark", "label": "Spark" },
            { "value": "star", "label": "Star" },
            { "value": "thumbs-down", "label": "Thumbs Down" },
            { "value": "thumbs-up", "label": "Thumbs Up" },
            { "value": "trash", "label": "Trash" },
            { "value": "truck", "label": "Lieferung" },
            { "value": "volume-max", "label": "Volume Max" },
            { "value": "wifi", "label": "WiFi" }
          ]
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Eigenes Icon"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optionaler Link"
        },
        {
          "type": "checkbox",
          "id": "hide_icon",
          "label": "Icon ausblenden",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "title": "Free Shipping",
            "text": "<p>over €99 in DE</p>",
            "icon_style": "box"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "Pay Later",
            "text": "<p>up to 30 days</p>",
            "icon_style": "credit-card"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "Handmade",
            "text": "<p>in Venice, Italy</p>",
            "icon_style": "hand-heart"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "100% Vegan",
            "text": "<p>just pure Cotton</p>",
            "icon_style": "leaf"
          }
        }
      ]
    }
  ]
}
{% endschema %}
