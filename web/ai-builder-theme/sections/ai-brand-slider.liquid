      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "Logo height desktop",
      "default": 52
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo height mobile",
      "default": 38
