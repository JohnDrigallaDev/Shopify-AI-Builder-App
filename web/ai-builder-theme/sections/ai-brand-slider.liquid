      "step": 1,
      "unit": "px",
      "label": "Icon size desktop",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Icon size mobile",
      "default": 16
    },
    {
