<section
  id="MainProduct-{{ section.id }}"
  class="page-width section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
  {{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer" type="module"></script>
  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}

  <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
    <div class="grid__item product__media-wrapper{% if section.settings.media_position == 'right' %} medium-hide large-up-hide{% endif %}">
      {% render 'product-media-gallery', variant_images: variant_images %}
    </div>
    <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}">
      <product-info
        id="ProductInfo-{{ section.id }}"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
      >
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'text' -%}
              <p
                class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </p>
            {%- when 'title' -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h1>{{ product.title | escape }}</h1>
                <a href="{{ product.url }}" class="product__title">
                  <h2 class="h1">
                    {{ product.title | escape }}
                  </h2>
                </a>
              </div>
            {%- when 'price' -%}
              <div class="no-js-hidden" id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_badges: true,
                  price_class: 'price--large'
                -%}
              </div>
              {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                <div class="product__tax caption rte">
                  {%- if shop.taxes_included -%}
                    {{ 'products.product.include_taxes' | t }}
                  {%- endif -%}
                  {%- if shop.shipping_policy.body != blank -%}
                    {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- endif -%}
                </div>
              {%- endif -%}
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                  {% render 'selling-plans' %}
                {%- endform -%}
              </div>
            {%- when 'inventory' -%}
              <p
                class="product__inventory no-js-hidden{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                {{ block.shopify_attributes }}
                id="Inventory-{{ section.id }}"
                role="status"
              >
                {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                  {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity <= block.settings.inventory_threshold -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(238,148,65, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(238,148,65)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{- 'products.product.inventory_low_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}
                      {%- else -%}
                        {{- 'products.product.inventory_low_stock' | t -}}
                      {%- endif -%}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{- 'products.product.inventory_in_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}
                      {%- else -%}
                          {{- 'products.product.inventory_in_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- else -%}
                    {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(200,200,200, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(200,200,200)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock' | t -}}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              </p>
            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
                  {{ product.description }}
                </div>
              {%- endif -%}
            {%- when 'sku' -%}
              <p
                class="product__sku no-js-hidden{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                id="Sku-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span> {{- product.selected_or_first_available_variant.sku -}}
              </p>
            {%- when 'ai_trust_badges' -%}
              <section
                id="ai-trust-badges-{{ section.id }}-{{ block.id }}"
                class="ai-trust-badges-section ai-trust-badges-section--product-info"
                style="
                  --atb-outer-bg: {{ block.settings.outer_bg }};
                  --atb-card-bg: {{ block.settings.card_bg }};
                  --atb-card-border: {{ block.settings.card_border_color }};
                  --atb-card-border-width: {{ block.settings.card_border_width }}px;
                  --atb-card-radius: {{ block.settings.card_radius }}px;
                  --atb-card-shadow: 0 {{ block.settings.card_shadow_strength | divided_by: 2.0 }}px {{ block.settings.card_shadow_strength | times: 2 }}px rgba(0,0,0,0.10);
                  --atb-heading-color: {{ block.settings.heading_color }};
                  --atb-text-color: {{ block.settings.text_color }};
                  --atb-icon-color: {{ block.settings.icon_color }};
                  --atb-gap-desktop: {{ block.settings.grid_gap_desktop }}px;
                  --atb-gap-mobile: {{ block.settings.grid_gap_mobile }}px;
                  --atb-pad-y: {{ block.settings.card_padding_y }}px;
                  --atb-pad-x: {{ block.settings.card_padding_x }}px;
                  --atb-icon-size: {{ block.settings.icon_size }}px;
                  --atb-icon-size-mobile: {{ block.settings.icon_size_mobile }}px;
                  --atb-heading-size: {{ block.settings.heading_size }}px;
                  --atb-heading-size-mobile: {{ block.settings.heading_size_mobile }}px;
                  --atb-text-size: {{ block.settings.text_size }}px;
                  --atb-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --atb-product-info-padding-top: {{ block.settings.padding_top }}px;
                  --atb-product-info-padding-bottom: {{ block.settings.padding_bottom }}px;
                  --atb-product-info-mobile-columns: {{ block.settings.columns_mobile }};
                  background: var(--atb-outer-bg);
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-trust-badges__inner">
                  <div class="ai-trust-badges__grid">
                  {%- if block.settings.badge_1_title != blank -%}
                    <div class="ai-trust-badges__item">
                      <div class="ai-trust-badges__card">
                        <div class="ai-trust-badges__icon">
                          {% case block.settings.badge_1_icon_style %}
                            {% when 'shield' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Zm0 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z"/></svg>
                            {% when 'klarna' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h3v16H5zm5 0h3v7.2L19 4h4.2l-6.7 8.1 7.1 7.9h-4.4L13 12.8V20h-3z"/></svg>
                            {% when 'scoop' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.5c0-1.4 1.1-2.5 2.5-2.5.4-2 2.1-3.5 4.2-3.5 1.4 0 2.8.7 3.6 1.9.4-.2.9-.4 1.5-.4 1.7 0 3.2 1.2 3.5 2.9 1.1.3 1.9 1.3 1.9 2.5 0 1.4-1.1 2.6-2.6 2.6H7.1c-1.7 0-3.1-1.4-3.1-3.1Zm3.2 5h8.2l1.8 3.7H9.1Zm9.8-.2 2.8-.9 1.2 3.4-2.8.9z"/></svg>
                            {% else %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5"/></svg>
                          {% endcase %}
                        </div>
                        <div class="ai-trust-badges__content">
                          <h3 class="ai-trust-badges__title">{{ block.settings.badge_1_title }}</h3>
                        {%- if block.settings.badge_1_text != blank -%}
                            <div class="ai-trust-badges__text rte"><p>{{ block.settings.badge_1_text }}</p></div>
                        {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.badge_2_title != blank -%}
                    <div class="ai-trust-badges__item">
                      <div class="ai-trust-badges__card">
                        <div class="ai-trust-badges__icon">
                          {% case block.settings.badge_2_icon_style %}
                            {% when 'shield' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Zm0 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z"/></svg>
                            {% when 'klarna' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h3v16H5zm5 0h3v7.2L19 4h4.2l-6.7 8.1 7.1 7.9h-4.4L13 12.8V20h-3z"/></svg>
                            {% when 'scoop' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.5c0-1.4 1.1-2.5 2.5-2.5.4-2 2.1-3.5 4.2-3.5 1.4 0 2.8.7 3.6 1.9.4-.2.9-.4 1.5-.4 1.7 0 3.2 1.2 3.5 2.9 1.1.3 1.9 1.3 1.9 2.5 0 1.4-1.1 2.6-2.6 2.6H7.1c-1.7 0-3.1-1.4-3.1-3.1Zm3.2 5h8.2l1.8 3.7H9.1Zm9.8-.2 2.8-.9 1.2 3.4-2.8.9z"/></svg>
                            {% else %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5"/></svg>
                          {% endcase %}
                        </div>
                        <div class="ai-trust-badges__content">
                          <h3 class="ai-trust-badges__title">{{ block.settings.badge_2_title }}</h3>
                        {%- if block.settings.badge_2_text != blank -%}
                            <div class="ai-trust-badges__text rte"><p>{{ block.settings.badge_2_text }}</p></div>
                        {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.badge_3_title != blank -%}
                    <div class="ai-trust-badges__item">
                      <div class="ai-trust-badges__card">
                        <div class="ai-trust-badges__icon">
                          {% case block.settings.badge_3_icon_style %}
                            {% when 'shield' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Zm0 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z"/></svg>
                            {% when 'klarna' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h3v16H5zm5 0h3v7.2L19 4h4.2l-6.7 8.1 7.1 7.9h-4.4L13 12.8V20h-3z"/></svg>
                            {% when 'scoop' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.5c0-1.4 1.1-2.5 2.5-2.5.4-2 2.1-3.5 4.2-3.5 1.4 0 2.8.7 3.6 1.9.4-.2.9-.4 1.5-.4 1.7 0 3.2 1.2 3.5 2.9 1.1.3 1.9 1.3 1.9 2.5 0 1.4-1.1 2.6-2.6 2.6H7.1c-1.7 0-3.1-1.4-3.1-3.1Zm3.2 5h8.2l1.8 3.7H9.1Zm9.8-.2 2.8-.9 1.2 3.4-2.8.9z"/></svg>
                            {% else %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5"/></svg>
                          {% endcase %}
                        </div>
                        <div class="ai-trust-badges__content">
                          <h3 class="ai-trust-badges__title">{{ block.settings.badge_3_title }}</h3>
                        {%- if block.settings.badge_3_text != blank -%}
                            <div class="ai-trust-badges__text rte"><p>{{ block.settings.badge_3_text }}</p></div>
                        {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.badge_4_title != blank -%}
                    <div class="ai-trust-badges__item">
                      <div class="ai-trust-badges__card">
                        <div class="ai-trust-badges__icon">
                          {% case block.settings.badge_4_icon_style %}
                            {% when 'shield' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Zm0 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z"/></svg>
                            {% when 'klarna' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h3v16H5zm5 0h3v7.2L19 4h4.2l-6.7 8.1 7.1 7.9h-4.4L13 12.8V20h-3z"/></svg>
                            {% when 'scoop' %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.5c0-1.4 1.1-2.5 2.5-2.5.4-2 2.1-3.5 4.2-3.5 1.4 0 2.8.7 3.6 1.9.4-.2.9-.4 1.5-.4 1.7 0 3.2 1.2 3.5 2.9 1.1.3 1.9 1.3 1.9 2.5 0 1.4-1.1 2.6-2.6 2.6H7.1c-1.7 0-3.1-1.4-3.1-3.1Zm3.2 5h8.2l1.8 3.7H9.1Zm9.8-.2 2.8-.9 1.2 3.4-2.8.9z"/></svg>
                            {% else %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5"/></svg>
                          {% endcase %}
                        </div>
                        <div class="ai-trust-badges__content">
                          <h3 class="ai-trust-badges__title">{{ block.settings.badge_4_title }}</h3>
                        {%- if block.settings.badge_4_text != blank -%}
                            <div class="ai-trust-badges__text rte"><p>{{ block.settings.badge_4_text }}</p></div>
                        {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                  </div>
                </div>
              </section>
            {%- when 'ai_social_proof_bar' -%}
              <section
                id="ai-social-proof-bar-{{ section.id }}-{{ block.id }}"
                class="ai-social-proof-bar-section ai-social-proof-bar-section--product-info"
                style="
                  --asp-section-bg: {{ block.settings.section_bg }};
                  --asp-card-bg: {{ block.settings.card_bg }};
                  --asp-card-border: {{ block.settings.card_border }};
                  --asp-card-border-width: {{ block.settings.card_border_width }}px;
                  --asp-card-radius: {{ block.settings.card_radius }}px;
                  --asp-card-shadow: 0 {{ block.settings.card_shadow_strength | divided_by: 2.0 }}px {{ block.settings.card_shadow_strength | times: 2 }}px rgba(0,0,0,0.10);
                  --asp-card-padding-x: {{ block.settings.card_padding_x }}px;
                  --asp-card-padding-y: {{ block.settings.card_padding_y }}px;
                  --asp-card-min-height: {{ block.settings.card_min_height }}px;
                  --asp-items-gap-desktop: {{ block.settings.items_gap_desktop }}px;
                  --asp-items-gap-mobile: {{ block.settings.items_gap_mobile }}px;
                  --asp-avatar-size: {{ block.settings.avatar_size }}px;
                  --asp-avatar-size-mobile: {{ block.settings.avatar_size_mobile }}px;
                  --asp-avatar-border-width: {{ block.settings.avatar_border_width }}px;
                  --asp-avatar-overlap: {{ block.settings.avatar_overlap }}px;
                  --asp-avatar-ring-color: {{ block.settings.avatar_ring_color }};
                  --asp-verified-bg: {{ block.settings.verified_bg }};
                  --asp-verified-icon: {{ block.settings.verified_icon_color }};
                  --asp-verified-size: {{ block.settings.verified_size }}px;
                  --asp-verified-size-mobile: {{ block.settings.verified_size_mobile }}px;
                  --asp-text-color: {{ block.settings.text_color }};
                  --asp-strong-color: {{ block.settings.strong_color }};
                  --asp-text-size: {{ block.settings.text_size }}px;
                  --asp-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --asp-line-height: {{ block.settings.line_height }};
                  background: var(--asp-section-bg);
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-social-proof-bar__inner">
                  <div class="ai-social-proof-bar__stack">
                    <div class="ai-social-proof-bar__item">
                      <div class="ai-social-proof-bar__card{% if block.settings.use_card %} is-card{% else %} is-plain{% endif %}">
                        <div class="ai-social-proof-bar__media ai-social-proof-bar__media--{{ block.settings.layout_mode }}">
                          {% if block.settings.layout_mode == 'single' %}
                            <div class="ai-social-proof-bar__avatar-wrap">
                              <div class="ai-social-proof-bar__avatar">
                                {% if block.settings.avatar_1 != blank %}
                                  <img src="{{ block.settings.avatar_1 | image_url: width: 120 }}" alt="{{ block.settings.name_1 | escape }}" loading="lazy">
                                {% else %}
                                  <div class="ai-social-proof-bar__avatar-placeholder"></div>
                                {% endif %}
                              </div>
                              {% if block.settings.show_verified %}
                                <div class="ai-social-proof-bar__verified-badge">
                                  <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9.2 12.9l1.8 1.8 3.8-4.1"/>
                                  </svg>
                                </div>
                              {% endif %}
                            </div>
                          {% else %}
                            <div class="ai-social-proof-bar__avatar-group">
                              <div class="ai-social-proof-bar__avatar">
                                {% if block.settings.avatar_1 != blank %}
                                  <img src="{{ block.settings.avatar_1 | image_url: width: 120 }}" alt="{{ block.settings.name_1 | escape }}" loading="lazy">
                                {% else %}
                                  <div class="ai-social-proof-bar__avatar-placeholder"></div>
                                {% endif %}
                              </div>
                              <div class="ai-social-proof-bar__avatar">
                                {% if block.settings.avatar_2 != blank %}
                                  <img src="{{ block.settings.avatar_2 | image_url: width: 120 }}" alt="{{ block.settings.name_2 | escape }}" loading="lazy">
                                {% else %}
                                  <div class="ai-social-proof-bar__avatar-placeholder"></div>
                                {% endif %}
                              </div>
                              {% if block.settings.show_verified %}
                                <div class="ai-social-proof-bar__verified-badge ai-social-proof-bar__verified-badge--group">
                                  <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9.2 12.9l1.8 1.8 3.8-4.1"/>
                                  </svg>
                                </div>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                        <div class="ai-social-proof-bar__text rte">
                          {{ block.settings.content }}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
            {%- when 'ai_product_title' -%}
              <section
                id="ai-product-title-{{ section.id }}-{{ block.id }}"
                class="ai-product-title-section ai-product-title-section--product-info"
                style="
                  --apt-title-color: {{ block.settings.title_color }};
                  --apt-title-size: {{ block.settings.title_size }}px;
                  --apt-title-size-mobile: {{ block.settings.title_size_mobile }}px;
                  --apt-font-weight: {{ block.settings.font_weight }};
                  --apt-line-height: {{ block.settings.line_height }};
                  --apt-letter-spacing: {{ block.settings.letter_spacing }}px;
                  --apt-text-transform: {{ block.settings.text_transform }};
                  --apt-product-info-margin-top: {{ block.settings.margin_top }}px;
                  --apt-product-info-margin-bottom: {{ block.settings.margin_bottom }}px;
                  --apt-product-info-padding-side: {{ block.settings.padding_side }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-title__inner ai-product-title__inner--{{ block.settings.text_alignment }}">
                  {%- if product.title != blank -%}
                    <h1 class="ai-product-title__text">
                      {{ product.title }}
                    </h1>
                  {%- endif -%}
                </div>
              </section>
            {%- when 'ai_payment_icons' -%}
              {%- assign manual_icons = block.settings.manual_icons | downcase | strip_html | replace: '-', '_' | replace: ' ', '' | split: ',' -%}
              <section
                id="ai-payment-icons-{{ section.id }}-{{ block.id }}"
                class="ai-payment-icons-section ai-payment-icons-section--product-info"
                style="
                  --api-section-bg: {{ block.settings.section_bg }};
                  --api-card-bg: {{ block.settings.card_bg }};
                  --api-card-border: {{ block.settings.card_border_color }};
                  --api-card-border-width: {{ block.settings.card_border_width }}px;
                  --api-card-radius: {{ block.settings.card_radius }}px;
                  --api-card-padding-y: {{ block.settings.card_padding_y }}px;
                  --api-card-padding-x: {{ block.settings.card_padding_x }}px;
                  --api-item-gap: {{ block.settings.item_gap }}px;
                  --api-row-gap: {{ block.settings.row_gap }}px;
                  --api-icon-height: {{ block.settings.icon_height }}px;
                  --api-icon-height-mobile: {{ block.settings.icon_height_mobile }}px;
                  --api-icon-padding-x: {{ block.settings.icon_padding_x }}px;
                  --api-icon-padding-y: {{ block.settings.icon_padding_y }}px;
                  --api-icon-bg: {{ block.settings.icon_bg }};
                  --api-icon-border: {{ block.settings.icon_border_color }};
                  --api-icon-border-width: {{ block.settings.icon_border_width }}px;
                  --api-icon-radius: {{ block.settings.icon_radius }}px;
                  --api-heading-size: {{ block.settings.heading_size }}px;
                  --api-heading-size-mobile: {{ block.settings.heading_size_mobile }}px;
                  --api-heading-color: {{ block.settings.heading_color }};
                  --api-product-info-padding-top: {{ block.settings.padding_top }}px;
                  --api-product-info-padding-bottom: {{ block.settings.padding_bottom }}px;
                  background: var(--api-section-bg);
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-payment-icons__inner">
                  {% if block.settings.show_wrapper %}
                    <div class="ai-payment-icons__box">
                  {% endif %}

                  {% if block.settings.show_heading and block.settings.heading != blank %}
                    <h2 class="ai-payment-icons__heading">{{ block.settings.heading }}</h2>
                  {% endif %}

                  <ul
                    class="ai-payment-icons__list ai-payment-icons__list--desktop-{{ block.settings.align_desktop }} ai-payment-icons__list--mobile-{{ block.settings.align_mobile }}"
                    role="list"
                  >
                    {% if block.settings.source_mode == 'shopify' %}
                      {% for type in shop.enabled_payment_types %}
                        <li class="ai-payment-icons__item">
                          <div class="ai-payment-icons__icon-holder">
                            {{ type | payment_type_svg_tag: class: 'ai-payment-icons__svg' }}
                          </div>
                        </li>
                      {% endfor %}
                    {% else %}
                      {% for type in manual_icons %}
                        {% assign cleaned_type = type | strip %}
                        {% if cleaned_type != blank %}
                          <li class="ai-payment-icons__item">
                            <div class="ai-payment-icons__icon-holder">
                              {{ cleaned_type | payment_type_svg_tag: class: 'ai-payment-icons__svg' }}
                            </div>
                          </li>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </ul>

                  {% if block.settings.show_wrapper %}
                    </div>
                  {% endif %}
                </div>
              </section>
            {%- when 'ai_price_highlight' -%}
              {%- assign price_target = product.selected_or_first_available_variant -%}
              {%- assign compare_at_price = price_target.compare_at_price -%}
              {%- assign price = price_target.price -%}
              {%- assign has_discount = false -%}
              {%- if compare_at_price > price -%}
                {%- assign has_discount = true -%}
              {%- endif -%}
              {%- assign discount_percent = 0 -%}
              {%- if has_discount and compare_at_price > 0 -%}
                {%- assign discount_percent = compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | round -%}
              {%- endif -%}
              {%- if settings.currency_code_enabled -%}
                {%- assign formatted_price = price | money_with_currency -%}
                {%- assign formatted_compare_at_price = compare_at_price | money_with_currency -%}
              {%- else -%}
                {%- assign formatted_price = price | money -%}
                {%- assign formatted_compare_at_price = compare_at_price | money -%}
              {%- endif -%}
              {%- assign badge_prefix = block.settings.badge_prefix -%}
              {%- assign badge_suffix = block.settings.badge_suffix -%}
              {%- if badge_prefix == blank -%}
                {%- assign badge_prefix = 'SPARE ' -%}
              {%- endif -%}
              {%- if badge_suffix == blank -%}
                {%- assign badge_suffix = '%' -%}
              {%- endif -%}
              <section
                id="ai-product-price-highlight-{{ section.id }}-{{ block.id }}"
                class="ai-product-price-highlight-section ai-product-price-highlight-section--product-info"
                style="
                  --apph-sale-color: {{ block.settings.sale_price_color }};
                  --apph-compare-color: {{ block.settings.compare_price_color }};
                  --apph-compare-line: {{ block.settings.compare_line_color }};
                  --apph-sale-size: {{ block.settings.sale_price_size }}px;
                  --apph-sale-size-mobile: {{ block.settings.sale_price_size_mobile }}px;
                  --apph-compare-size: {{ block.settings.compare_price_size }}px;
                  --apph-compare-size-mobile: {{ block.settings.compare_price_size_mobile }}px;
                  --apph-sale-weight: {{ block.settings.font_weight_sale }};
                  --apph-compare-weight: {{ block.settings.font_weight_compare }};
                  --apph-gap: {{ block.settings.gap }}px;
                  --apph-badge-bg: {{ block.settings.badge_bg }};
                  --apph-badge-text: {{ block.settings.badge_text_color }};
                  --apph-badge-border: {{ block.settings.badge_border_color }};
                  --apph-badge-border-width: {{ block.settings.badge_border_width }}px;
                  --apph-badge-radius: {{ block.settings.badge_radius }}px;
                  --apph-badge-pad-y: {{ block.settings.badge_padding_y }}px;
                  --apph-badge-pad-x: {{ block.settings.badge_padding_x }}px;
                  --apph-badge-text-size: {{ block.settings.badge_text_size }}px;
                  --apph-badge-text-size-mobile: {{ block.settings.badge_text_size_mobile }}px;
                  --apph-badge-gap: {{ block.settings.badge_gap }}px;
                  --apph-badge-icon-size: {{ block.settings.badge_icon_size }}px;
                  --apph-compare-line-thickness: {{ block.settings.compare_line_thickness }}px;
                  --apph-compare-line-rotation: {{ block.settings.compare_line_rotation }}deg;
                  --apph-product-info-margin-top: {{ block.settings.margin_top }}px;
                  --apph-product-info-margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-price-highlight__inner ai-product-price-highlight__inner--desktop-{{ block.settings.align_desktop }} ai-product-price-highlight__inner--mobile-{{ block.settings.align_mobile }}{% if block.settings.wrap_mobile %} ai-product-price-highlight__inner--wrap-mobile{% endif %}">
                  <div class="ai-product-price-highlight__row">
                    {%- if has_discount -%}
                      <div class="ai-product-price-highlight__compare-wrap">
                        <span class="ai-product-price-highlight__compare-price">{{ formatted_compare_at_price }}</span>
                      </div>
                    {%- endif -%}

                    <div class="ai-product-price-highlight__sale-wrap">
                      <span class="ai-product-price-highlight__sale-price">{{ formatted_price }}</span>
                    </div>

                    {%- if has_discount and block.settings.show_badge -%}
                      <div class="ai-product-price-highlight__badge">
                        <span class="ai-product-price-highlight__badge-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none">
                            <path d="M12 2.75 21.25 12 12 21.25 2.75 12 12 2.75Z" fill="currentColor"/>
                            <path d="M9.25 8.85h.01M14.75 15.15h.01M15.2 8.8l-6.4 6.4" stroke="{{ block.settings.badge_bg }}" stroke-width="1.8" stroke-linecap="round"/>
                            <circle cx="9.25" cy="8.85" r="1.25" fill="{{ block.settings.badge_bg }}"/>
                            <circle cx="14.75" cy="15.15" r="1.25" fill="{{ block.settings.badge_bg }}"/>
                          </svg>
                        </span>
                        <span class="ai-product-price-highlight__badge-text">
                          <span class="ai-product-price-highlight__badge-prefix">{{ badge_prefix }}</span>
                          <span class="ai-product-price-highlight__badge-value">{{ discount_percent }}{{ badge_suffix }}</span>
                        </span>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </section>
            {%- when 'ai_product_teaser_text' -%}
              <section
                id="ai-product-teaser-text-{{ section.id }}-{{ block.id }}"
                class="ai-product-teaser-text-section ai-product-teaser-text-section--product-info"
                style="
                  --aptt-text-color: {{ block.settings.text_color }};
                  --aptt-text-size: {{ block.settings.text_size }}px;
                  --aptt-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --aptt-font-weight: {{ block.settings.font_weight }};
                  --aptt-line-height: {{ block.settings.line_height }};
                  --aptt-letter-spacing: {{ block.settings.letter_spacing }}px;
                  --aptt-product-info-margin-top: {{ block.settings.margin_top }}px;
                  --aptt-product-info-margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-teaser-text__inner ai-product-teaser-text__inner--{{ block.settings.text_alignment }}">
                  {%- if block.settings.text != blank -%}
                    <div class="ai-product-teaser-text__text{% if block.settings.uppercase %} is-uppercase{% endif %}">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                </div>
              </section>
            {%- when 'ai_product_divider' -%}
              <section
                id="ai-product-divider-{{ section.id }}-{{ block.id }}"
                class="ai-product-divider-section ai-product-divider-section--product-info"
                style="
                  --apd-line-color: {{ block.settings.line_color }};
                  --apd-line-thickness: {{ block.settings.line_thickness }}px;
                  --apd-line-width: {{ block.settings.line_width }}%;
                  --apd-line-opacity: {{ block.settings.line_opacity }};
                  --apd-product-info-margin-top: {{ block.settings.margin_top }}px;
                  --apd-product-info-margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-divider__inner ai-product-divider__inner--{{ block.settings.line_alignment }}">
                  <div class="ai-product-divider__line" aria-hidden="true"></div>
                </div>
              </section>
            {%- when 'ai_price_badge' -%}
              <section
                id="ai-price-badge-{{ section.id }}-{{ block.id }}"
                class="ai-price-badge-section ai-price-badge-section--product-info"
                style="
                  --aprice-bg: {{ block.settings.badge_bg }};
                  --aprice-text: {{ block.settings.text_color }};
                  --aprice-border: {{ block.settings.border_color }};
                  --aprice-border-width: {{ block.settings.border_width }}px;
                  --aprice-radius: {{ block.settings.radius }}px;
                  --aprice-shadow: 0 {{ block.settings.shadow_strength | divided_by: 2.0 }}px {{ block.settings.shadow_strength | times: 2 }}px rgba(0,0,0,0.12);
                  --aprice-padding-y: {{ block.settings.padding_y }}px;
                  --aprice-padding-x: {{ block.settings.padding_x }}px;
                  --aprice-text-size: {{ block.settings.text_size }}px;
                  --aprice-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --aprice-font-weight: {{ block.settings.font_weight }};
                  --aprice-arrow-size: {{ block.settings.arrow_size }}px;
                  --aprice-arrow-offset: {{ block.settings.arrow_offset }}px;
                  --aprice-product-info-padding-top: {{ block.settings.padding_top }}px;
                  --aprice-product-info-padding-bottom: {{ block.settings.padding_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-price-badge__inner ai-price-badge__inner--desktop-{{ block.settings.align_desktop }} ai-price-badge__inner--mobile-{{ block.settings.align_mobile }}">
                  <div class="ai-price-badge__wrap">
                    <div class="ai-price-badge__badge{% if block.settings.uppercase %} is-uppercase{% endif %}{% if block.settings.arrow_position != 'none' %} has-arrow has-arrow--{{ block.settings.arrow_position }}{% endif %}">
                      <span class="ai-price-badge__text">{{ block.settings.badge_text }}</span>
                    </div>
                  </div>
                </div>
              </section>
            {%- when 'ai_product_pills' -%}
              <section
                id="ai-product-pills-{{ section.id }}-{{ block.id }}"
                class="ai-product-pills-section ai-product-pills-section--product-info"
                style="
                  --app-section-bg: {{ block.settings.section_bg }};
                  --app-gap-desktop: {{ block.settings.gap_desktop }}px;
                  --app-gap-mobile: {{ block.settings.gap_mobile }}px;
                  --app-pill-padding-y: {{ block.settings.pill_padding_y }}px;
                  --app-pill-padding-x: {{ block.settings.pill_padding_x }}px;
                  --app-pill-radius: {{ block.settings.pill_radius }}px;
                  --app-pill-border-width: {{ block.settings.pill_border_width }}px;
                  --app-text-size: {{ block.settings.text_size }}px;
                  --app-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --app-font-weight: {{ block.settings.font_weight }};
                  --app-icon-size: {{ block.settings.icon_size }}px;
                  --app-icon-size-mobile: {{ block.settings.icon_size_mobile }}px;
                  --app-icon-gap: {{ block.settings.icon_gap }}px;
                  --app-min-height: {{ block.settings.min_height }}px;
                  background: var(--app-section-bg);
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-pills__inner">
                  <div class="ai-product-pills__list ai-product-pills__list--desktop-left ai-product-pills__list--mobile-left">
                    {%- for index in (1..6) -%}
                      {%- assign text_key = 'pill_' | append: index | append: '_text' -%}
                      {%- assign emoji_key = 'pill_' | append: index | append: '_emoji_icon' -%}
                      {%- assign image_key = 'pill_' | append: index | append: '_custom_icon' -%}
                      {%- assign bg_key = 'pill_' | append: index | append: '_bg' -%}
                      {%- assign text_color_key = 'pill_' | append: index | append: '_text_color' -%}
                      {%- assign border_color_key = 'pill_' | append: index | append: '_border_color' -%}
                      {%- assign pill_text = block.settings[text_key] | strip -%}
                      {%- assign emoji_icon = block.settings[emoji_key] | strip -%}
                      {%- assign custom_icon = block.settings[image_key] -%}
                      {%- if pill_text != blank -%}
                        <div class="ai-product-pills__item">
                          <div
                            class="ai-product-pills__pill"
                            style="
                              --app-pill-bg: {{ block.settings[bg_key] }};
                              --app-pill-text: {{ block.settings[text_color_key] }};
                              --app-pill-border: {{ block.settings[border_color_key] }};
                            "
                          >
                            {%- if custom_icon != blank -%}
                              <span class="ai-product-pills__icon ai-product-pills__icon--image">
                                {{
                                  custom_icon
                                  | image_url: width: 120
                                  | image_tag:
                                    class: 'ai-product-pills__icon-image',
                                    widths: '40,60,80,120',
                                    loading: 'lazy',
                                    alt: pill_text
                                }}
                              </span>
                            {%- elsif emoji_icon != blank -%}
                              <span class="ai-product-pills__icon ai-product-pills__icon--emoji">{{ emoji_icon }}</span>
                            {%- endif -%}
                            <span class="ai-product-pills__text">{{ pill_text }}</span>
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </section>
            {%- when 'ai_product_benefits' -%}
              <section
                id="ai-product-benefits-{{ section.id }}-{{ block.id }}"
                class="ai-product-benefits-section ai-product-benefits-section--product-info"
                style="
                  --apb-section-bg: {{ block.settings.section_bg }};
                  --apb-card-bg: {{ block.settings.card_bg }};
                  --apb-card-border: {{ block.settings.card_border_color }};
                  --apb-card-border-width: {{ block.settings.card_border_width }}px;
                  --apb-card-radius: {{ block.settings.card_radius }}px;
                  --apb-card-padding-y: {{ block.settings.card_padding_y }}px;
                  --apb-card-padding-x: {{ block.settings.card_padding_x }}px;
                  --apb-card-shadow: 0 {{ block.settings.shadow_strength | divided_by: 2.0 }}px {{ block.settings.shadow_strength | times: 2 }}px rgba(0,0,0,0.10);
                  --apb-gap-desktop: {{ block.settings.gap_desktop }}px;
                  --apb-gap-mobile: {{ block.settings.gap_mobile }}px;
                  --apb-icon-size: {{ block.settings.icon_size }}px;
                  --apb-icon-size-mobile: {{ block.settings.icon_size_mobile }}px;
                  --apb-icon-color: {{ block.settings.icon_color }};
                  --apb-icon-bg: {{ block.settings.icon_bg }};
                  --apb-icon-border: {{ block.settings.icon_border_color }};
                  --apb-icon-border-width: {{ block.settings.icon_border_width }}px;
                  --apb-icon-radius: {{ block.settings.icon_radius }}px;
                  --apb-text-size: {{ block.settings.text_size }}px;
                  --apb-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --apb-text-color: {{ block.settings.text_color }};
                  --apb-font-weight: {{ block.settings.font_weight }};
                  --apb-product-info-padding-top: {{ block.settings.padding_top }}px;
                  --apb-product-info-padding-bottom: {{ block.settings.padding_bottom }}px;
                  background: var(--apb-section-bg);
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-product-benefits__inner">
                  <div class="ai-product-benefits__grid ai-product-benefits__grid--desktop-{{ block.settings.columns_desktop }} ai-product-benefits__grid--mobile-{{ block.settings.columns_mobile }}">
                    {%- for index in (1..6) -%}
                      {%- assign enabled_key = 'show_benefit_' | append: index -%}
                      {%- assign text_key = 'benefit_' | append: index | append: '_text' -%}
                      {%- assign icon_key = 'benefit_' | append: index | append: '_icon_style' -%}
                      {%- assign image_key = 'benefit_' | append: index | append: '_custom_icon' -%}
                      {%- assign benefit_enabled = block.settings[enabled_key] -%}
                      {%- assign benefit_text = block.settings[text_key] | strip -%}
                      {%- assign benefit_icon = block.settings[icon_key] -%}
                      {%- assign benefit_image = block.settings[image_key] -%}
                      {%- if benefit_enabled and benefit_text != blank -%}
                        <div class="ai-product-benefits__item">
                          <div class="ai-product-benefits__card{% if block.settings.show_pill_style %} is-pill{% endif %}">
                            <div class="ai-product-benefits__icon-wrap">
                              {%- if benefit_image != blank -%}
                                <div class="ai-product-benefits__icon ai-product-benefits__icon--image">
                                  {{
                                    benefit_image
                                    | image_url: width: 120
                                    | image_tag:
                                      class: 'ai-product-benefits__icon-image',
                                      widths: '40,60,80,120',
                                      loading: 'lazy',
                                      alt: benefit_text
                                  }}
                                </div>
                              {%- else -%}
                                <div class="ai-product-benefits__icon" aria-hidden="true">
                                  {%- case benefit_icon -%}
                                    {%- when 'box' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                    {%- when 'return' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M8 8 4 12l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M5 12h7c4.4 0 7 2.6 7 6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                      </svg>
                                    {%- when 'truck' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M3 6h11v8H3zM14 9h3l3 3v2h-6z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                        <circle cx="8" cy="17.5" r="1.5" fill="currentColor"/>
                                        <circle cx="18" cy="17.5" r="1.5" fill="currentColor"/>
                                      </svg>
                                    {%- when 'shield' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                        <path d="m9.5 11.8 1.6 1.7 3.4-3.7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                    {%- when 'star' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="m12 3.8 2.4 4.8 5.3.8-3.9 3.8.9 5.4L12 16.1 7.3 18.6l.9-5.4L4.3 9.4l5.3-.8L12 3.8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                      </svg>
                                    {%- when 'leaf' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M18.5 5.5c-6.8 0-11 3.8-11 9.2 0 2.4 1.9 4.3 4.2 4.3 4.8 0 6.8-4.5 6.8-8.6V5.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                        <path d="M8 18c1.6-2.6 4-4.8 7.5-6.7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                                      </svg>
                                    {%- when 'heart' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M12 20s-6.8-4.3-8.5-8C2.1 8.8 4 5.5 7.4 5.5c2 0 3.4 1 4.6 2.6 1.2-1.6 2.6-2.6 4.6-2.6C20 5.5 21.9 8.8 20.5 12 18.8 15.7 12 20 12 20Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                      </svg>
                                    {%- when 'clock' -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.7"/>
                                        <path d="M12 7.8v4.6l3 1.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                    {%- else -%}
                                      <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M12 3.5 14.2 5l2.7-.2 1.2 2.4 2.3 1.5-.7 2.6.7 2.7-2.3 1.4-1.2 2.4-2.7-.2L12 20.5l-2.2-1.5-2.7.2-1.2-2.4-2.3-1.4.7-2.7-.7-2.6 2.3-1.5 1.2-2.4 2.7.2L12 3.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                                        <path d="m9.3 12.2 1.8 1.8 3.6-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                  {%- endcase -%}
                                </div>
                              {%- endif -%}
                            </div>
                            <div class="ai-product-benefits__text">{{ benefit_text }}</div>
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </section>
            {%- when 'ai_promo_code_banner' -%}
              <section
                id="ai-promo-code-banner-{{ section.id }}-{{ block.id }}"
                class="ai-promo-code-banner-section ai-promo-code-banner-section--product-info"
                style="
                  --apcb-bg: {{ block.settings.bg_color }};
                  --apcb-border-color: {{ block.settings.border_color }};
                  --apcb-border-width: {{ block.settings.border_width }}px;
                  --apcb-radius: {{ block.settings.radius }}px;
                  --apcb-shadow: 0 {{ block.settings.shadow_strength | divided_by: 2.0 }}px {{ block.settings.shadow_strength | times: 2 }}px rgba(0,0,0,0.12);
                  --apcb-content-pad-y: {{ block.settings.content_padding_y }}px;
                  --apcb-content-pad-x: {{ block.settings.content_padding_x }}px;
                  --apcb-gap: {{ block.settings.gap }}px;
                  --apcb-icon-size: {{ block.settings.icon_size }}px;
                  --apcb-icon-color: {{ block.settings.icon_color }};
                  --apcb-text-color: {{ block.settings.text_color }};
                  --apcb-accent-text-color: {{ block.settings.accent_text_color }};
                  --apcb-text-size: {{ block.settings.text_size }}px;
                  --apcb-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                  --apcb-code-size: {{ block.settings.code_size }}px;
                  --apcb-code-size-mobile: {{ block.settings.code_size_mobile }}px;
                  --apcb-button-bg: {{ block.settings.button_bg }};
                  --apcb-button-text: {{ block.settings.button_text_color }};
                  --apcb-button-border: {{ block.settings.button_border_color }};
                  --apcb-button-border-width: {{ block.settings.button_border_width }}px;
                  --apcb-button-radius: {{ block.settings.button_radius }}px;
                  --apcb-button-pad-y: {{ block.settings.button_padding_y }}px;
                  --apcb-button-pad-x: {{ block.settings.button_padding_x }}px;
                  --apcb-product-info-padding-top: {{ block.settings.padding_top }}px;
                  --apcb-product-info-padding-bottom: {{ block.settings.padding_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="ai-promo-code-banner__inner">
                  <div
                    class="ai-promo-code-banner__card"
                    style="background: var(--apcb-bg);"
                  >
                    <div class="ai-promo-code-banner__left">
                      {% if block.settings.show_icon %}
                        <div class="ai-promo-code-banner__icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none">
                            <path d="M3.8 5.4h6.8c.5 0 1 .2 1.4.6l8 8c.8.8.8 2 0 2.8l-3.2 3.2c-.8.8-2 .8-2.8 0l-8-8c-.4-.4-.6-.9-.6-1.4V3.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="8.1" cy="8.1" r="1.25" stroke="currentColor" stroke-width="1.8"/>
                          </svg>
                        </div>
                      {% endif %}

                      <div class="ai-promo-code-banner__text-wrap">
                        {% if block.settings.text != blank %}
                          <div class="ai-promo-code-banner__text">
                            {{ block.settings.text }}
                          </div>
                        {% endif %}
                      </div>
                    </div>

                    <div class="ai-promo-code-banner__right">
                      <button
                        type="button"
                        class="ai-promo-code-banner__copy-btn"
                        data-copy-btn
                        data-copy-value="{{ block.settings.promo_code | escape }}"
                        data-copy-label="{{ block.settings.copy_label | escape }}"
                        data-copied-label="{{ block.settings.copied_label | escape }}"
                        data-success-text="{{ block.settings.success_text | escape }}"
                        aria-label="{{ block.settings.copy_label | default: block.settings.promo_code | escape }}"
                      >
                        <span class="ai-promo-code-banner__copy-code{% if block.settings.code_case == 'uppercase' %} is-uppercase{% elsif block.settings.code_case == 'lowercase' %} is-lowercase{% endif %}">
                          {{ block.settings.copy_label | default: block.settings.promo_code | escape }}
                        </span>

                        <span class="ai-promo-code-banner__copy-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none">
                            <path d="M9 9.8V7.6c0-1 .8-1.8 1.8-1.8h6c1 0 1.8.8 1.8 1.8v8.6c0 1-.8 1.8-1.8 1.8h-6c-1 0-1.8-.8-1.8-1.8V9.8Zm-3.8 8.6h6.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M5.2 15.2c-1 0-1.8-.8-1.8-1.8V7.6c0-1 .8-1.8 1.8-1.8H11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </span>
                      </button>

                      <div class="ai-promo-code-banner__status" data-copy-status aria-live="polite"></div>
                    </div>
                  </div>
                </div>
              </section>
            {%- when 'collapsible_tab' -%}
              <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                <details id="Details-{{ block.id }}-{{ section.id }}">
                  <summary>
                    <div class="summary__title">
                      {% render 'icon-accordion', icon: block.settings.icon %}
                      <h2 class="h4 accordion__title inline-richtext">
                        {{ block.settings.heading | default: block.settings.page.title }}
                      </h2>
                    </div>
                    {% render 'icon-caret' %}
                  </summary>
                  <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                  </div>
                </details>
              </div>
            {%- when 'quantity_selector' -%}
              <div
                id="Quantity-Form-{{ section.id }}"
                class="product-form__input product-form__quantity{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} product-form__quantity-top{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% comment %} TODO: enable theme-check once `item_count_for_variant` is accepted as valid filter {% endcomment %}
                {% # theme-check-disable %}
                {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}
                {% # theme-check-enable %}
                <label class="quantity__label form__label" for="Quantity-{{ section.id }}">
                  {{ 'products.product.quantity.label' | t }}
                  <span class="quantity__rules-cart no-js-hidden{% if cart_qty == 0 %} hidden{% endif %}">
                    <span class="loading-overlay hidden">
                      <span class="loading-overlay__spinner">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          class="spinner"
                          viewBox="0 0 66 66"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </span>
                    </span>
                    <span>({{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}})</span>
                  </span>
                </label>
                <quantity-input class="quantity">
                  <button class="quantity__button no-js-hidden" name="minus" type="button">
                    <span class="visually-hidden">
                      {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                    </span>
                    {% render 'icon-minus' %}
                  </button>
                  <input
                    class="quantity__input"
                    type="number"
                    name="quantity"
                    id="Quantity-{{ section.id }}"
                    data-cart-quantity="{{ cart_qty }}"
                    data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                      data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                      max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                    {% endif %}
                    step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                    value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    form="{{ product_form_id }}"
                  />
                  <button class="quantity__button no-js-hidden" name="plus" type="button">
                    <span class="visually-hidden">
                      {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                    </span>
                    {% render 'icon-plus' %}
                  </button>
                </quantity-input>
                <div class="quantity__rules caption no-js-hidden">
                  {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.multiples_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                      -}}
                    </span>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.minimum_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                      -}}
                    </span>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.maximum_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                      -}}
                    </span>
                  {%- endif -%}
                </div>
              </div>
            {%- when 'popup' -%}
              <modal-opener
                class="product-popup-modal__opener no-js-hidden quick-add-hidden"
                data-modal="#PopupModal-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <button
                  id="ProductPopup-{{ block.id }}"
                  class="product-popup-modal__button link"
                  type="button"
                  aria-haspopup="dialog"
                >
                  {{ block.settings.text | default: block.settings.page.title }}
                </button>
              </modal-opener>
              <a href="{{ block.settings.page.url }}" class="product-popup-modal__button link no-js">
                {{- block.settings.text -}}
              </a>
            {%- when 'share' -%}
              {% assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin %}
              {% render 'share-button',
                block: block,
                share_link: share_url
              %}
            {%- when 'variant_picker' -%}
              {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
            {%- when 'buy_buttons' -%}
              {%- render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true -%}
            {%- when 'ai_buy_button' -%}
              {%- assign ai_buy_variant = product.selected_or_first_available_variant -%}
              {%- assign ai_buy_form_id = 'ai-buy-button-form-' | append: section.id | append: '-' | append: block.id -%}
              <div
                id="ai-buy-button-{{ section.id }}-{{ block.id }}"
                class="ai-buy-button-block"
                style="
                  --ai-buy-button-bg: {{ block.settings.button_bg }};
                  --ai-buy-button-color: {{ block.settings.button_text_color }};
                  --ai-buy-button-border: {{ block.settings.button_border_color }};
                  --ai-buy-button-bg-hover: {{ block.settings.button_bg_hover }};
                  --ai-buy-button-color-hover: {{ block.settings.button_text_color_hover }};
                  --ai-buy-button-border-hover: {{ block.settings.button_border_color_hover }};
                  --ai-buy-button-height: {{ block.settings.button_height }}px;
                  --ai-buy-button-radius: {{ block.settings.button_radius }}px;
                  --ai-buy-button-font-size: {{ block.settings.button_font_size }}px;
                  --ai-buy-button-font-weight: {{ block.settings.button_font_weight }};
                  --ai-buy-button-margin-top: {{ block.settings.margin_top }}px;
                  --ai-buy-button-margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                {%- form 'product', product, id: ai_buy_form_id, class: 'ai-buy-button-block__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                  <input
                    type="hidden"
                    name="id"
                    value="{{ ai_buy_variant.id }}"
                    class="product-variant-id"
                    {% if ai_buy_variant.available == false %}
                      disabled
                    {% endif %}
                  >
                  <div class="ai-buy-button-block__buttons">
                    <button
                      type="submit"
                      name="add"
                      class="ai-buy-button-block__submit"
                      {% if ai_buy_variant == nil or ai_buy_variant.available == false %}
                        disabled
                      {% endif %}
                    >
                      <span>
                        {%- if ai_buy_variant == nil -%}
                          {{ block.settings.unavailable_text }}
                        {%- elsif ai_buy_variant.available -%}
                          {{ block.settings.button_text }}
                        {%- else -%}
                          {{ block.settings.sold_out_text }}
                        {%- endif -%}
                      </span>
                    </button>
                    {%- if block.settings.show_dynamic_checkout -%}
                      <div class="ai-buy-button-block__dynamic-checkout">
                        {{ form | payment_button }}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endform -%}
              </div>
            {%- when 'rating' -%}
              {%- if product.metafields.reviews.rating.value != blank -%}
                {% liquid
                  assign rating_decimal = 0
                  assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                  if decimal >= 0.3 and decimal <= 0.7
                    assign rating_decimal = 0.5
                  elsif decimal > 0.7
                    assign rating_decimal = 1
                  endif
                %}
                <div
                  class="rating"
                  role="img"
                  aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}"
                >
                  <span
                    aria-hidden="true"
                    class="rating-star color-icon-{{ settings.accent_icons }}"
                    style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
                  ></span>
                </div>
                <p class="rating-text caption">
                  <span aria-hidden="true">
                    {{- product.metafields.reviews.rating.value }} /
                    {{ product.metafields.reviews.rating.value.scale_max -}}
                  </span>
                </p>
                <p class="rating-count caption">
                  <span aria-hidden="true">({{ product.metafields.reviews.rating_count }})</span>
                  <span class="visually-hidden">
                    {{- product.metafields.reviews.rating_count }}
                    {{ 'accessibility.total_reviews' | t -}}
                  </span>
                </p>
              {%- endif -%}
            {%- when 'complementary' -%}
              <product-recommendations class="complementary-products quick-add-hidden no-js-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary">
                {%- if recommendations.performed and recommendations.products_count > 0 -%}
                  <aside aria-label="{{ 'accessibility.complementary_products' | t }}" {{ block.shopify_attributes }}{% if block.settings.make_collapsible_row %} class="product__accordion accordion"{% endif %}>
                    <div class="complementary-products__container">
                      {%- if block.settings.make_collapsible_row -%}
                        <details id="Details-{{ block.id }}-{{ section.id }}" open>
                          <summary>
                      {%- endif %}
                      <div class="summary__title">
                        {%- if block.settings.make_collapsible_row -%}
                          {% render 'icon-accordion', icon: block.settings.icon %}
                          <h2 class="h4 accordion__title">{{ block.settings.block_heading }}</h2>
                        {%- else -%}
                          <h2 class="h3 accordion__title">{{ block.settings.block_heading }}</h2>
                        {%- endif -%}
                      </div>
                      {%- if block.settings.make_collapsible_row -%}
                          {% render 'icon-caret' %}
                        </summary>
                      {%- endif -%}
                      <slideshow-component class="slider-mobile-gutter">
                        {%- assign number_of_slides = recommendations.products_count | plus: 0.0 | divided_by: block.settings.products_per_page | ceil -%}
                        <div id="Slider-{{ block.id }}" class="contains-card contains-card--product complementary-slider grid grid--1-col slider slider--everywhere" role="list"{% if number_of_slides > 1 %} aria-label="{{ 'general.slider.name' | t }}"{% endif %}>
                          {%- for i in (1..number_of_slides) -%}
                            <div id="Slide-{{ block.id }}-{{ forloop.index }}" class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide" tabindex="-1" role="group"{% if number_of_slides > 1 %} aria-roledescription="{{ 'sections.slideshow.slide' | t }}" aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"{% endif %}>
                              <ul class="list-unstyled" role="list">
                                {%- for product in recommendations.products limit: block.settings.products_per_page offset: continue -%}
                                  <li>
                                    {% render 'card-product',
                                      card_product: product,
                                      media_aspect_ratio: block.settings.image_ratio,
                                      show_secondary_image: false,
                                      lazy_load: false,
                                      show_quick_add: block.settings.enable_quick_add,
                                      section_id: section.id,
                                      horizontal_class: true,
                                      horizontal_quick_add: true
                                    %}
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </div>
                          {%- endfor -%}
                        </div>
                        {%- if number_of_slides > 1 -%}
                          <div class="slider-buttons no-js-hidden">
                            <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">{% render 'icon-caret' %}</button>
                            <div class="slider-counter slider-counter--{{ block.settings.pagination_style }}{% if block.settings.pagination_style == 'counter' or block.settings.pagination_style == 'numbers' %} caption{% endif %}">
                              {%- if block.settings.pagination_style == 'counter' -%}
                                <span class="slider-counter--current">1</span>
                                <span aria-hidden="true"> / </span>
                                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                <span class="slider-counter--total">{{ number_of_slides }}</span>
                              {%- else -%}
                                <div class="slideshow__control-wrapper">
                                  {%- for i in (1..number_of_slides) -%}
                                    <button class="slider-counter__link slider-counter__link--{{ block.settings.pagination_style }} link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}" aria-controls="Slider-{{ block.id }}">
                                      {%- if block.settings.pagination_style == 'numbers' -%}{{ forloop.index }}{% else %}<span class="dot"></span>{%- endif -%}
                                    </button>
                                  {%- endfor -%}
                                </div>
                              {%- endif -%}
                            </div>
                            <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">{% render 'icon-caret' %}</button>
                          </div>
                        {%- endif -%}
                      </slideshow-component>
                      {%- if block.settings.make_collapsible_row -%}
                        </details>
                      {%- endif -%}
                    </div>
                  </aside>
                {%- endif -%}
                {{ 'component-card.css' | asset_url | stylesheet_tag }}
                {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                {%- if block.settings.enable_quick_add -%}
                  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
                  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                {%- endif -%}
              </product-recommendations>
            {%- when 'icon-with-text' -%}
              {% render 'icon-with-text',
                block: block
              %}
          {%- endcase -%}
        {%- endfor -%}
        <a href="{{ product.url }}" class="link product__view-details animate-arrow">
          {{ 'products.product.view_full_details' | t }}
          {% render 'icon-arrow' %}
        </a>
      </product-info>
    </div>
    {%- if section.settings.media_position == 'right' -%}
      {% comment %} Duplicate gallery to display after product content on tablet/desktop breakpoint {% endcomment %}
      <div class="grid__item product__media-wrapper small-hide">
        {% render 'product-media-gallery', variant_images: variant_images, is_duplicate: true %}
      </div>
    {%- endif -%}
  </div>

  {% render 'product-media-modal' variant_images: variant_images %}

  {% assign popups = section.blocks | where: 'type', 'popup' %}
  {%- for block in popups -%}
    <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
      <div
        role="dialog"
        aria-label="{{ block.settings.text }}"
        aria-modal="true"
        class="product-popup-modal__content"
        tabindex="-1"
      >
        <button
          id="ModalClose-{{ block.id }}"
          type="button"
          class="product-popup-modal__toggle"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="product-popup-modal__content-info">
          <h1 class="h2">{{ block.settings.page.title }}</h1>
          {{ block.settings.page.content }}
        </div>
      </div>
    </modal-dialog>
  {%- endfor -%}

  {%- if product.media.size > 0 -%}
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
    <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {%- endif -%}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');

        return msie > 0 || trident > 0;
      }

      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
        document.querySelector('variant-selects[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.product-form__noscript-wrapper-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
  </script>

  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
  <script src="{{ 'selling-plans.js' | asset_url }}" defer="defer"></script>
  {% comment %}<script src="{{ 'selling-plan-docs.js' | asset_url }}" defer="defer"></script>{% endcomment %}
  <script>
    (() => {
      const root = document.getElementById('MainProduct-{{ section.id }}');
      if (!root || root.dataset.aiPromoCopyReady === 'true') return;
      root.dataset.aiPromoCopyReady = 'true';

      const fallbackCopyText = (value) => {
        return new Promise((resolve, reject) => {
          const textarea = document.createElement('textarea');
          textarea.value = value;
          textarea.setAttribute('readonly', '');
          textarea.style.position = 'fixed';
          textarea.style.top = '0';
          textarea.style.left = '0';
          textarea.style.width = '1px';
          textarea.style.height = '1px';
          textarea.style.padding = '0';
          textarea.style.border = '0';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          textarea.setSelectionRange(0, textarea.value.length);

          try {
            if (!document.execCommand('copy')) {
              throw new Error('Copy command failed');
            }
            resolve();
          } catch (error) {
            reject(error);
          } finally {
            document.body.removeChild(textarea);
          }
        });
      };

      const copyText = async (value) => {
        if (navigator.clipboard && window.isSecureContext) {
          try {
            await navigator.clipboard.writeText(value);
            return;
          } catch (error) {
            return fallbackCopyText(value);
          }
        }

        return fallbackCopyText(value);
      };

      root.addEventListener('click', async (event) => {
        const button = event.target.closest('.ai-promo-code-banner-section--product-info [data-copy-btn]');
        if (!button) return;

        const value = button.getAttribute('data-copy-value') || '';
        const copyLabel = button.getAttribute('data-copy-label') || value;
        const copiedLabel = button.getAttribute('data-copied-label') || 'Copied';
        const successText = button.getAttribute('data-success-text') || '';
        const codeEl = button.querySelector('.ai-promo-code-banner__copy-code');
        const status = button
          .closest('.ai-promo-code-banner-section--product-info')
          ?.querySelector('[data-copy-status]');

        try {
          await copyText(value);
          if (codeEl) codeEl.textContent = copiedLabel;
          if (status) status.textContent = successText;
          clearTimeout(button._copyTimer);
          button._copyTimer = setTimeout(() => {
            if (codeEl) codeEl.textContent = copyLabel;
            if (status) status.textContent = '';
          }, 1800);
        } catch {
          if (status) status.textContent = 'Code konnte nicht kopiert werden';
        }
      });
    })();
  </script>
</section>

