{% liquid
  assign ai_page = product.metafields.ai_builder.page_json.value
  assign ai_section = blank

  if ai_page and ai_page.sections
    for page_section in ai_page.sections
      if page_section.type == 'cta_banner'
        assign ai_section = page_section
        break
      endif
    endfor
  endif

  assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker
  assign title = section.settings.title | strip | default: ai_section.title
  assign body = section.settings.body | strip | default: ai_section.body
  assign button_label = section.settings.button_label | strip | default: ai_section.buttonText
  assign button_link = section.settings.button_link | default: product.url
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign button_font = section.settings.button_font
%}

{% if eyebrow != blank or title != blank or body != blank or button_label != blank %}
  <style>
    {% if section.settings.heading_custom_font %}
      {{ heading_font | font_face: font_display: 'swap' }}
    {% endif %}

    {% if section.settings.body_custom_font %}
      {{ body_font | font_face: font_display: 'swap' }}
    {% endif %}

    {% if section.settings.button_custom_font %}
      {{ button_font | font_face: font_display: 'swap' }}
    {% endif %}

    #ai-cta-banner-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_sides_mobile }}px;
      padding-right: {{ section.settings.padding_sides_mobile }}px;
      background: {{ section.settings.section_background }};
      {% if section.settings.section_background_gradient != blank %}
        background: {{ section.settings.section_background_gradient }};
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__inner {
      max-width: {{ section.settings.content_width }}px;
      margin: 0 auto;
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__panel {
      display: grid;
      grid-template-columns: 1fr;
      gap: {{ section.settings.panel_gap_mobile }}px;
      align-items: center;
      padding: {{ section.settings.panel_padding_y_mobile }}px {{ section.settings.panel_padding_x_mobile }}px;
      border: {{ section.settings.panel_border_width }}px solid {{ section.settings.panel_border_color }};
      border-radius: {{ section.settings.panel_radius_mobile }}px;
      background: {{ section.settings.panel_background }};
      {% if section.settings.panel_background_gradient != blank %}
        background: {{ section.settings.panel_background_gradient }};
      {% endif %}
      {% if section.settings.panel_shadow_strength > 0 %}
        box-shadow: 0 {{ section.settings.panel_shadow_y }}px {{ section.settings.panel_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.panel_shadow_strength | divided_by: 100.0 }});
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__content {
      text-align: {{ section.settings.text_align_mobile }};
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__eyebrow {
      margin: 0 0 {{ section.settings.eyebrow_margin_bottom_mobile }}px;
      color: {{ section.settings.eyebrow_color }};
      font-size: {{ section.settings.eyebrow_size_mobile }}px;
      font-weight: {{ section.settings.eyebrow_weight }};
      line-height: {{ section.settings.eyebrow_line_height }}%;
      letter-spacing: {{ section.settings.eyebrow_letter_spacing }}px;
      text-transform: {{ section.settings.eyebrow_transform }};
      {% if section.settings.body_custom_font %}
        font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
        font-style: {{ body_font.style }};
      {% else %}
        font-family: var(--font-body-family);
        font-style: var(--font-body-style);
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__title {
      margin: 0;
      color: {{ section.settings.title_color }};
      font-size: {{ section.settings.title_size_mobile }}px;
      font-weight: {{ section.settings.title_weight }};
      line-height: {{ section.settings.title_line_height_mobile }}%;
      letter-spacing: {{ section.settings.title_letter_spacing }}px;
      {% if section.settings.heading_custom_font %}
        font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        font-style: {{ heading_font.style }};
      {% else %}
        font-family: var(--font-heading-family);
        font-style: var(--font-heading-style);
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__body {
      margin-top: {{ section.settings.body_margin_top_mobile }}px;
      color: {{ section.settings.body_color }};
      {% if section.settings.body_custom_font %}
        font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
        font-style: {{ body_font.style }};
      {% else %}
        font-family: var(--font-body-family);
        font-style: var(--font-body-style);
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__body,
    #ai-cta-banner-{{ section.id }} .ai-cta-banner__body p {
      font-size: {{ section.settings.body_size_mobile }}px;
      font-weight: {{ section.settings.body_weight }};
      line-height: {{ section.settings.body_line_height_mobile }}%;
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__body p {
      margin: 0;
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__actions {
      display: flex;
      justify-content: {{ section.settings.button_align_mobile }};
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: {{ section.settings.button_min_width_mobile }}px;
      min-height: {{ section.settings.button_min_height_mobile }}px;
      padding: {{ section.settings.button_padding_y_mobile }}px {{ section.settings.button_padding_x_mobile }}px;
      border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
      border-radius: {{ section.settings.button_radius_mobile }}px;
      background: {{ section.settings.button_background }};
      color: {{ section.settings.button_text_color }};
      text-decoration: none;
      text-align: center;
      font-size: {{ section.settings.button_font_size_mobile }}px;
      font-weight: {{ section.settings.button_font_weight }};
      line-height: 1.1;
      transition: all .25s ease;
      {% if section.settings.button_custom_font %}
        font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
        font-style: {{ button_font.style }};
      {% else %}
        font-family: var(--font-body-family);
        font-style: var(--font-body-style);
      {% endif %}
    }

    #ai-cta-banner-{{ section.id }} .ai-cta-banner__button:hover {
      background: {{ section.settings.button_background_hover }};
      color: {{ section.settings.button_text_color_hover }};
      border-color: {{ section.settings.button_border_color_hover }};
    }

    @media screen and (min-width: 750px) {
      #ai-cta-banner-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        padding-left: {{ section.settings.padding_sides }}px;
        padding-right: {{ section.settings.padding_sides }}px;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__panel {
        grid-template-columns: minmax(0, 1fr) auto;
        gap: {{ section.settings.panel_gap }}px;
        padding: {{ section.settings.panel_padding_y }}px {{ section.settings.panel_padding_x }}px;
        border-radius: {{ section.settings.panel_radius }}px;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__content {
        text-align: {{ section.settings.text_align }};
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__eyebrow {
        margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
        font-size: {{ section.settings.eyebrow_size }}px;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__title {
        font-size: {{ section.settings.title_size }}px;
        line-height: {{ section.settings.title_line_height }}%;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__body {
        margin-top: {{ section.settings.body_margin_top }}px;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__body,
      #ai-cta-banner-{{ section.id }} .ai-cta-banner__body p {
        font-size: {{ section.settings.body_size }}px;
        line-height: {{ section.settings.body_line_height }}%;
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__actions {
        justify-content: {{ section.settings.button_align }};
      }

      #ai-cta-banner-{{ section.id }} .ai-cta-banner__button {
        min-width: {{ section.settings.button_min_width }}px;
        min-height: {{ section.settings.button_min_height }}px;
        padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
        border-radius: {{ section.settings.button_radius }}px;
        font-size: {{ section.settings.button_font_size }}px;
      }
    }
  </style>

  <section id="ai-cta-banner-{{ section.id }}">
    <div class="ai-cta-banner__inner">
      <div class="ai-cta-banner__panel">
        <div class="ai-cta-banner__content">
          {% if eyebrow != blank %}
            <p class="ai-cta-banner__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if title != blank %}
            <h2 class="ai-cta-banner__title">{{ title }}</h2>
          {% endif %}
          {% if body != blank %}
            <div class="ai-cta-banner__body rte">{{ body }}</div>
          {% endif %}
        </div>

        {% if button_label != blank %}
          <div class="ai-cta-banner__actions">
            <a class="ai-cta-banner__button" href="{{ button_link | default: '#' }}">
              {{ button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI CTA Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "checkbox",
      "id": "heading_custom_font",
      "label": "Use custom heading font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "playfair_display_n7"
    },
    {
      "type": "checkbox",
      "id": "body_custom_font",
      "label": "Use custom body font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "josefin_sans_n4"
    },
    {
      "type": "checkbox",
      "id": "button_custom_font",
      "label": "Use custom button font",
      "default": false
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Button font",
      "default": "josefin_sans_n7"
    },
    {
      "type": "header",
      "content": "Text styles"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow size desktop",
      "default": 13
    },
    {
      "type": "range",
      "id": "eyebrow_size_mobile",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow size mobile",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Eyebrow weight",
      "default": 700
    },
    {
      "type": "range",
      "id": "eyebrow_line_height",
      "min": 80,
      "max": 200,
      "step": 5,
      "unit": "%",
      "label": "Eyebrow line height",
      "default": 120
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "min": 0,
      "max": 6,
      "step": 0.5,
      "unit": "px",
      "label": "Eyebrow letter spacing",
      "default": 1
    },
    {
      "type": "select",
      "id": "eyebrow_transform",
      "label": "Eyebrow text transform",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ]
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow spacing desktop",
      "default": 10
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom_mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow spacing mobile",
      "default": 8
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Title size desktop",
      "default": 38
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 18,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Title size mobile",
      "default": 28
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "range",
      "id": "title_line_height",
      "min": 80,
