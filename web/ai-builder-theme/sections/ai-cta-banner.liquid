{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign ai_page = product.metafields.ai_builder.page_json.value %}
{% assign ai_section = blank %}

{% if ai_page and ai_page.sections %}
  {% for page_section in ai_page.sections %}
    {% if page_section.type == 'cta_banner' %}
      {% assign ai_section = page_section %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker %}
{% assign title = section.settings.title | strip | default: ai_section.title %}
{% assign body = section.settings.body | strip | default: ai_section.body %}
{% assign button_label = section.settings.button_label | strip | default: ai_section.buttonText %}
{% assign button_link = section.settings.button_link | default: product.url %}

{% if eyebrow != blank or title != blank or body != blank or button_label != blank %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__cta">
      <div>
        {% if eyebrow != blank %}
          <p class="ai-builder-section__eyebrow ai-builder-section__eyebrow--light">{{ eyebrow }}</p>
        {% endif %}
        {% if title != blank %}
          <h2 class="ai-builder-section__title">{{ title }}</h2>
        {% endif %}
        {% if body != blank %}
          <div class="ai-builder-section__body rte">{{ body | newline_to_br }}</div>
        {% endif %}
      </div>
      {% if button_label != blank %}
        <a class="ai-builder-section__button" href="{{ button_link | default: '#' }}">
          {{ button_label }}
        </a>
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI CTA Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "AI CTA Banner"
    }
  ]
}
{% endschema %}
