    },
    {
      "type": "range",
      "id": "ai_story_size_mobile",
      "min": 50,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Bubble size mobile",
      "default": 82
    },
    {
      "type": "range",
      "id": "ai_story_gap_desktop",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Gap desktop",
      "default": 18
    },
    {
      "type": "range",
      "id": "ai_story_gap_mobile",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Gap mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "ai_story_roundness",
      "min": 0,
