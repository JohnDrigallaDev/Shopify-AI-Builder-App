    },
    {
      "type": "range",
      "id": "ai_story_padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "ai_story_padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 10
    },
    {
      "type": "range",
      "id": "ai_story_side_padding_desktop",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Side padding desktop",
      "default": 10
    },
    {
      "type": "range",
      "id": "ai_story_side_padding_mobile",
      "min": 0,
      "max": 60,
      "step": 2,
