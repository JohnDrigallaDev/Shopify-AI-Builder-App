{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign ai_page = product.metafields.ai_builder.page_json.value %}
{% assign ai_section = blank %}

{% if ai_page and ai_page.sections %}
  {% for page_section in ai_page.sections %}
    {% if page_section.type == 'icon_feature_strip' %}
      {% assign ai_section = page_section %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker %}
{% assign title = section.settings.title | strip | default: ai_section.title %}

{% if eyebrow != blank or title != blank or ai_section.items != blank or section.blocks.size > 0 %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__strip">
      {% if eyebrow != blank or title != blank %}
        <div class="ai-builder-section__strip-head">
          {% if eyebrow != blank %}
            <p class="ai-builder-section__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if title != blank %}
            <h2 class="ai-builder-section__title">{{ title }}</h2>
          {% endif %}
        </div>
      {% endif %}
      <div class="ai-builder-section__strip-grid">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% assign item_text = block.settings.text | strip %}
            {% if item_text != blank %}
              <div class="ai-builder-section__strip-item" {{ block.shopify_attributes }}>
                <span class="ai-builder-section__icon"></span>
                <span>{{ item_text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        {% elsif ai_section.items != blank %}
          {% for item in ai_section.items %}
            {% assign item_text = item | strip %}
            {% if item_text != blank %}
              <div class="ai-builder-section__strip-item">
                <span class="ai-builder-section__icon"></span>
                <span>{{ item_text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI Icon Feature Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Icon Feature Strip"
    }
  ]
}
{% endschema %}
