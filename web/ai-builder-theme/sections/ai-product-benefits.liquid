{% liquid
  assign sid = section.id

  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_side = section.settings.padding_side

  assign bg_mode = section.settings.bg_mode
  assign bg_color = section.settings.bg_color
  assign bg_gradient = section.settings.bg_gradient

  assign card_bg = section.settings.card_bg
  assign card_border_color = section.settings.card_border_color
  assign card_border_width = section.settings.card_border_width
  assign card_radius = section.settings.card_radius
  assign card_padding_y = section.settings.card_padding_y
  assign card_padding_x = section.settings.card_padding_x
  assign shadow_strength = section.settings.shadow_strength

  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign gap_desktop = section.settings.gap_desktop
  assign gap_mobile = section.settings.gap_mobile

  assign item_align = section.settings.item_align
  assign icon_size = section.settings.icon_size
  assign icon_size_mobile = section.settings.icon_size_mobile
  assign icon_color = section.settings.icon_color
  assign icon_bg = section.settings.icon_bg
  assign icon_border_color = section.settings.icon_border_color
  assign icon_border_width = section.settings.icon_border_width
  assign icon_radius = section.settings.icon_radius

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile
  assign text_color = section.settings.text_color
  assign font_weight = section.settings.font_weight

  assign show_pill_style = section.settings.show_pill_style
%}

<section
  id="ai-product-benefits-{{ sid }}"
  class="ai-product-benefits-section"
  style="
    --apb-section-bg: {{ bg_color }};
    --apb-card-bg: {{ card_bg }};
    --apb-card-border: {{ card_border_color }};
    --apb-card-border-width: {{ card_border_width }}px;
    --apb-card-radius: {{ card_radius }}px;
    --apb-card-padding-y: {{ card_padding_y }}px;
    --apb-card-padding-x: {{ card_padding_x }}px;
    --apb-card-shadow: 0 {{ shadow_strength | divided_by: 2.0 }}px {{ shadow_strength | times: 2 }}px rgba(0,0,0,0.10);

    --apb-gap-desktop: {{ gap_desktop }}px;
    --apb-gap-mobile: {{ gap_mobile }}px;

    --apb-icon-size: {{ icon_size }}px;
    --apb-icon-size-mobile: {{ icon_size_mobile }}px;
    --apb-icon-color: {{ icon_color }};
    --apb-icon-bg: {{ icon_bg }};
    --apb-icon-border: {{ icon_border_color }};
    --apb-icon-border-width: {{ icon_border_width }}px;
    --apb-icon-radius: {{ icon_radius }}px;

    --apb-text-size: {{ text_size }}px;
    --apb-text-size-mobile: {{ text_size_mobile }}px;
    --apb-text-color: {{ text_color }};
    --apb-font-weight: {{ font_weight }};

    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_side }}px;
    padding-right: {{ padding_side }}px;
    {% if bg_mode == 'gradient' %}
      background: {{ bg_gradient }};
    {% else %}
      background: transparent;
    {% endif %}
  "
>
  <div
    class="ai-product-benefits__inner{% if section_width == 'custom' %} ai-product-benefits__inner--custom{% endif %}{% if section_width == 'full' %} ai-product-benefits__inner--full{% endif %}"
    {% if section_width == 'custom' %}
      style="max-width: {{ custom_width }}px;"
    {% endif %}
  >
    <div class="ai-product-benefits__grid">
      {% for block in section.blocks %}
        <div class="ai-product-benefits__item" {{ block.shopify_attributes }}>
          <div class="ai-product-benefits__card{% if show_pill_style %} is-pill{% endif %}">
            <div class="ai-product-benefits__icon-wrap">
              {% if block.settings.custom_icon != blank %}
                <div class="ai-product-benefits__icon ai-product-benefits__icon--image">
                  {{
                    block.settings.custom_icon
                    | image_url: width: 160
                    | image_tag:
                      class: 'ai-product-benefits__icon-image',
                      widths: '60,90,120,160',
                      loading: 'lazy',
                      alt: block.settings.text | escape
                  }}
                </div>
              {% else %}
                <div class="ai-product-benefits__icon" aria-hidden="true">
                  {% case block.settings.icon_style %}
                    {% when 'badge' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 3.5 14.2 5l2.7-.2 1.2 2.4 2.3 1.5-.7 2.6.7 2.7-2.3 1.4-1.2 2.4-2.7-.2L12 20.5l-2.2-1.5-2.7.2-1.2-2.4-2.3-1.4.7-2.7-.7-2.6 2.3-1.5 1.2-2.4 2.7.2L12 3.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="m9.3 12.2 1.8 1.8 3.6-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% when 'box' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M3 7.5 12 3l9 4.5M3 7.5V17l9 4 9-4V7.5M3 7.5 12 12m0 9v-9m0 0 9-4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% when 'return' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M8 8 4 12l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M5 12h7c4.4 0 7 2.6 7 6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                      </svg>
                    {% when 'truck' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M3 6h11v8H3zM14 9h3l3 3v2h-6z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <circle cx="8" cy="17.5" r="1.5" fill="currentColor"/>
                        <circle cx="18" cy="17.5" r="1.5" fill="currentColor"/>
                      </svg>
                    {% when 'shield' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 3l7 3v5c0 4.8-2.9 8.8-7 10-4.1-1.2-7-5.2-7-10V6l7-3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="m9.5 11.8 1.6 1.7 3.4-3.7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% when 'star' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="m12 3.8 2.4 4.8 5.3.8-3.9 3.8.9 5.4L12 16.1 7.3 18.6l.9-5.4L4.3 9.4l5.3-.8L12 3.8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                      </svg>
                    {% when 'leaf' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M18.5 5.5c-6.8 0-11 3.8-11 9.2 0 2.4 1.9 4.3 4.2 4.3 4.8 0 6.8-4.5 6.8-8.6V5.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M8 18c1.6-2.6 4-4.8 7.5-6.7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                      </svg>
                    {% when 'heart' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 20s-6.8-4.3-8.5-8C2.1 8.8 4 5.5 7.4 5.5c2 0 3.4 1 4.6 2.6 1.2-1.6 2.6-2.6 4.6-2.6C20 5.5 21.9 8.8 20.5 12 18.8 15.7 12 20 12 20Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                      </svg>
                    {% when 'clock' %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.7"/>
                        <path d="M12 7.8v4.6l3 1.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% else %}
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 3.5 14.2 5l2.7-.2 1.2 2.4 2.3 1.5-.7 2.6.7 2.7-2.3 1.4-1.2 2.4-2.7-.2L12 20.5l-2.2-1.5-2.7.2-1.2-2.4-2.3-1.4.7-2.7-.7-2.6 2.3-1.5 1.2-2.4 2.7.2L12 3.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="m9.3 12.2 1.8 1.8 3.6-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                  {% endcase %}
                </div>
              {% endif %}
            </div>

            {% if block.settings.text != blank %}
              <div class="ai-product-benefits__text">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #ai-product-benefits-{{ sid }} .ai-product-benefits__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__inner--full {
    max-width: 100%;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__grid {
    display: grid;
    grid-template-columns: repeat({{ columns_mobile }}, minmax(0, 1fr));
    gap: var(--apb-gap-mobile);
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__card {
    display: flex;
    align-items: {{ item_align }};
    gap: 10px;
    min-height: 34px;
    padding: var(--apb-card-padding-y) var(--apb-card-padding-x);
    border-radius: var(--apb-card-radius);
    border: var(--apb-card-border-width) solid var(--apb-card-border);
    background: var(--apb-card-bg);
    box-shadow: var(--apb-card-shadow);
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__card.is-pill {
    border-radius: 999px;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon {
    width: var(--apb-icon-size-mobile);
    min-width: var(--apb-icon-size-mobile);
    height: var(--apb-icon-size-mobile);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--apb-icon-color);
    background: var(--apb-icon-bg);
    border: var(--apb-icon-border-width) solid var(--apb-icon-border);
    border-radius: var(--apb-icon-radius);
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon--image {
    overflow: hidden;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon svg,
  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon-image {
    width: 100%;
    height: 100%;
    display: block;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon svg {
    padding: 4px;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__icon-image {
    object-fit: contain;
  }

  #ai-product-benefits-{{ sid }} .ai-product-benefits__text {
    color: var(--apb-text-color);
    font-size: var(--apb-text-size-mobile);
    line-height: 1.25;
    font-weight: var(--apb-font-weight);
    letter-spacing: -0.01em;
    word-break: break-word;
  }

  @media screen and (min-width: 750px) {
    #ai-product-benefits-{{ sid }} .ai-product-benefits__grid {
      grid-template-columns: repeat({{ columns_desktop }}, minmax(0, 1fr));
      gap: var(--apb-gap-desktop);
    }

    #ai-product-benefits-{{ sid }} .ai-product-benefits__icon {
      width: var(--apb-icon-size);
      min-width: var(--apb-icon-size);
      height: var(--apb-icon-size);
    }

    #ai-product-benefits-{{ sid }} .ai-product-benefits__text {
      font-size: var(--apb-text-size);
    }
  }
</style>

{% schema %}
{
  "name": "AI Product Benefits",
  "tag": "section",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Breite"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Breite",
      "default": "full",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Breite",
      "min": 280,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 800
    },

    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Spalten Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Spalten Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Abstand Desktop",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Abstand Mobile",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },

    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "checkbox",
      "id": "show_pill_style",
      "label": "Pill Style nutzen",
      "default": false
    },
    {
      "type": "select",
      "id": "item_align",
      "label": "Vertikale Ausrichtung",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Oben" },
        { "value": "center", "label": "Mitte" }
      ]
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "label": "Padding oben/unten",
      "min": 4,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "label": "Padding links/rechts",
      "min": 6,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Border",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_strength",
      "label": "Shadow Stärke",
      "min": 0,
      "max": 18,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Größe Desktop",
      "min": 14,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon Größe Mobile",
      "min": 12,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_radius",
      "label": "Icon Radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "icon_border_width",
      "label": "Icon Border",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "Typografie"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Textgröße Desktop",
      "min": 11,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Textgröße Mobile",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Schriftstärke",
      "default": "500",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },

    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "select",
      "id": "bg_mode",
      "label": "Section Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 100%)"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Hintergrund",
      "default": "#fbe7f3"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border",
      "default": "#efc8de"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Farbe",
      "default": "#d97eb5"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon Border Farbe",
      "default": "#efc8de"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Farbe",
      "default": "#d97eb5"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "High Quality"
        },
        {
          "type": "select",
          "id": "icon_style",
          "label": "Vordefiniertes Icon",
          "default": "badge",
          "options": [
            { "value": "badge", "label": "Qualität / Badge" },
            { "value": "box", "label": "Box / Versand" },
            { "value": "return", "label": "Returns / Zurück" },
            { "value": "truck", "label": "Truck / Lieferung" },
            { "value": "shield", "label": "Shield / Sicherheit" },
            { "value": "star", "label": "Star / Bewertung" },
            { "value": "leaf", "label": "Leaf / Natürlich" },
            { "value": "heart", "label": "Heart / Love" },
            { "value": "clock", "label": "Clock / Schnell" }
          ]
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Eigenes Icon (überschreibt Dropdown)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Product Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "High Quality",
            "icon_style": "badge"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Fast shipping",
            "icon_style": "box"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Free returns",
            "icon_style": "return"
          }
        }
      ]
    }
  ]
}
{% endschema %}
