{% liquid
  assign desktop_image = section.settings.pai_desktop_image
  assign mobile_image = section.settings.pai_mobile_image

  assign heading_font = section.settings.pai_heading_font
  assign body_font = section.settings.pai_body_font
  assign button_font = section.settings.pai_button_font
  assign overlay_alpha = section.settings.pai_overlay_opacity | times: 0.01
  assign hero_alt = desktop_image.alt | default: mobile_image.alt | default: section.settings.pai_heading | strip_html
%}

<style>
  {% if section.settings.pai_heading_use_custom_font %}
    {{ heading_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.pai_body_use_custom_font %}
    {{ body_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.pai_button_use_custom_font %}
    {{ button_font | font_face: font_display: 'swap' }}
  {% endif %}

  #pai-hero-{{ section.id }} {
    background: {{ section.settings.pai_section_background }};
    margin-top: {{ section.settings.pai_margin_top }}px;
    margin-bottom: {{ section.settings.pai_margin_bottom }}px;
  }

  #pai-hero-{{ section.id }} .pai-hero-frame {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.pai_desktop_height }}px;
    border-radius: {{ section.settings.pai_desktop_radius }}px;
  }

  #pai-hero-{{ section.id }} .pai-hero-picture,
  #pai-hero-{{ section.id }} .pai-hero-picture img,
  #pai-hero-{{ section.id }} .pai-hero-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #pai-hero-{{ section.id }} .pai-hero-picture img {
    object-fit: cover;
    object-position: {{ section.settings.pai_desktop_image_position }};
    display: block;
  }

  #pai-hero-{{ section.id }} .pai-hero-placeholder {
    background: #f2f2f2;
    display: grid;
    place-items: center;
    color: #999;
    font-size: 18px;
  }

  #pai-hero-{{ section.id }} .pai-hero-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.pai_overlay_color | color_modify: 'alpha', overlay_alpha }};
    pointer-events: none;
  }

  #pai-hero-{{ section.id }} .pai-hero-content {
    position: relative;
    z-index: 2;
    min-height: {{ section.settings.pai_desktop_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.pai_desktop_vertical_position }};
    align-items: {{ section.settings.pai_desktop_horizontal_position }};
    max-width: {{ section.settings.pai_desktop_content_width }}px;
    padding-top: {{ section.settings.pai_desktop_padding_top }}px;
    padding-bottom: {{ section.settings.pai_desktop_padding_bottom }}px;
    padding-left: {{ section.settings.pai_desktop_padding_left }}px;
    padding-right: {{ section.settings.pai_desktop_padding_right }}px;
    text-align: {{ section.settings.pai_desktop_text_align }};
  }

  #pai-hero-{{ section.id }} .pai-hero-heading {
    margin: 0;
    {% if section.settings.pai_heading_use_custom_font %}
      font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      font-style: {{ heading_font.style }};
    {% else %}
      font-family: var(--font-heading-family);
      font-style: var(--font-heading-style);
    {% endif %}
    font-weight: {{ section.settings.pai_heading_weight }};
    font-size: {{ section.settings.pai_heading_size_desktop }}px;
    line-height: {{ section.settings.pai_heading_line_height }}%;
    letter-spacing: {{ section.settings.pai_heading_letter_spacing }}px;
    color: {{ section.settings.pai_heading_color_desktop }};
    max-width: {{ section.settings.pai_heading_max_width_desktop }}px;
  }

  #pai-hero-{{ section.id }} .pai-hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: {{ section.settings.pai_button_margin_top_desktop }}px;
    min-width: {{ section.settings.pai_button_min_width_desktop }}px;
    min-height: {{ section.settings.pai_button_height_desktop }}px;
    padding: {{ section.settings.pai_button_padding_y_desktop }}px {{ section.settings.pai_button_padding_x_desktop }}px;
    border-radius: {{ section.settings.pai_button_radius }}px;
    border: {{ section.settings.pai_button_border_width }}px solid {{ section.settings.pai_button_border_color }};
    background: {{ section.settings.pai_button_background }};
    color: {{ section.settings.pai_button_text_color }};
    {% if section.settings.pai_button_use_custom_font %}
      font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
      font-style: {{ button_font.style }};
    {% else %}
      font-family: var(--font-body-family);
      font-style: var(--font-body-style);
    {% endif %}
    font-size: {{ section.settings.pai_button_font_size_desktop }}px;
    font-weight: {{ section.settings.pai_button_font_weight }};
    line-height: 1.1;
    text-decoration: none;
    text-align: center;
    transition: all .25s ease;
  }

  #pai-hero-{{ section.id }} .pai-hero-button:hover {
    background: {{ section.settings.pai_button_background_hover }};
    color: {{ section.settings.pai_button_text_color_hover }};
    border-color: {{ section.settings.pai_button_border_color_hover }};
  }

  #pai-hero-{{ section.id }} .pai-hero-note {
    margin: {{ section.settings.pai_note_margin_top_desktop }}px 0 0;
    {% if section.settings.pai_body_use_custom_font %}
      font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
      font-style: {{ body_font.style }};
    {% else %}
      font-family: var(--font-body-family);
      font-style: var(--font-body-style);
    {% endif %}
    font-size: {{ section.settings.pai_note_size_desktop }}px;
    font-weight: {{ section.settings.pai_note_weight }};
    line-height: {{ section.settings.pai_note_line_height }}%;
    color: {{ section.settings.pai_note_color_desktop }};
    max-width: {{ section.settings.pai_note_max_width_desktop }}px;
  }

  #pai-hero-{{ section.id }} .pai-hero-note strong {
    font-weight: 800;
  }

  @media screen and (max-width: 749px) {
    #pai-hero-{{ section.id }} {
      margin-top: {{ section.settings.pai_margin_top_mobile }}px;
      margin-bottom: {{ section.settings.pai_margin_bottom_mobile }}px;
    }

    #pai-hero-{{ section.id }} .pai-hero-frame {
      min-height: {{ section.settings.pai_mobile_height }}px;
      border-radius: {{ section.settings.pai_mobile_radius }}px;
    }

    #pai-hero-{{ section.id }} .pai-hero-picture img {
      object-position: {{ section.settings.pai_mobile_image_position }};
    }

    #pai-hero-{{ section.id }} .pai-hero-content {
      min-height: {{ section.settings.pai_mobile_height }}px;
      max-width: 100%;
      justify-content: {{ section.settings.pai_mobile_vertical_position }};
      align-items: {{ section.settings.pai_mobile_horizontal_position }};
      text-align: {{ section.settings.pai_mobile_text_align }};
      padding-top: {{ section.settings.pai_mobile_padding_top }}px;
      padding-bottom: {{ section.settings.pai_mobile_padding_bottom }}px;
      padding-left: {{ section.settings.pai_mobile_padding_left }}px;
      padding-right: {{ section.settings.pai_mobile_padding_right }}px;
    }

    #pai-hero-{{ section.id }} .pai-hero-heading {
      font-size: {{ section.settings.pai_heading_size_mobile }}px;
      line-height: {{ section.settings.pai_heading_line_height_mobile }}%;
      color: {{ section.settings.pai_heading_color_mobile }};
      max-width: {{ section.settings.pai_heading_max_width_mobile }}px;
    }

    #pai-hero-{{ section.id }} .pai-hero-button {
      margin-top: {{ section.settings.pai_button_margin_top_mobile }}px;
      min-width: {{ section.settings.pai_button_min_width_mobile }}px;
      min-height: {{ section.settings.pai_button_height_mobile }}px;
      padding: {{ section.settings.pai_button_padding_y_mobile }}px {{ section.settings.pai_button_padding_x_mobile }}px;
      font-size: {{ section.settings.pai_button_font_size_mobile }}px;
    }

    #pai-hero-{{ section.id }} .pai-hero-note {
      margin-top: {{ section.settings.pai_note_margin_top_mobile }}px;
      font-size: {{ section.settings.pai_note_size_mobile }}px;
      color: {{ section.settings.pai_note_color_mobile }};
      max-width: {{ section.settings.pai_note_max_width_mobile }}px;
      {% if section.settings.pai_hide_note_mobile %}
        display: none;
      {% endif %}
    }
  }
</style>

<section id="pai-hero-{{ section.id }}">
  <div class="pai-hero-frame">
    <picture class="pai-hero-picture">
      {% if mobile_image != blank %}
        <source
          media="(max-width: 749px)"
          srcset="{{ mobile_image | image_url: width: 1200 }}"
        >
      {% endif %}

      {% if desktop_image != blank %}
        {{
          desktop_image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            alt: hero_alt
        }}
      {% elsif mobile_image != blank %}
        {{
          mobile_image
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            alt: hero_alt
        }}
      {% else %}
        <div class="pai-hero-placeholder">Hero image</div>
      {% endif %}
    </picture>

    <div class="pai-hero-overlay"></div>

    <div class="pai-hero-content">
      {% if section.settings.pai_heading != blank %}
        <h2 class="pai-hero-heading">
          {{ section.settings.pai_heading }}
        </h2>
      {% endif %}

      {% if section.settings.pai_button_label != blank %}
        <a
          class="pai-hero-button"
          {% if section.settings.pai_button_link != blank %}
            href="{{ section.settings.pai_button_link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
        >
          {{ section.settings.pai_button_label }}
        </a>
      {% endif %}

      {% if section.settings.pai_note != blank %}
        <p class="pai-hero-note">
          {{ section.settings.pai_note }}
        </p>
      {% endif %}
    </div>
  </div>
</section>

