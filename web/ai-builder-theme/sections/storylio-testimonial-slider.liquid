{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign slider_id = 'storylio-slider-' | append: section.id %}

<section class="ai-builder-section page-width storylio-slider">
  {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.text != blank %}
    <div class="storylio-slider__header">
      {% if section.settings.eyebrow != blank %}
        <p class="ai-builder-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ai-builder-section__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="ai-builder-section__body rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="storylio-slider__rail" id="{{ slider_id }}">
    {% for block in section.blocks %}
      <article class="storylio-slider__card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="storylio-slider__media">
            {{
              block.settings.image
              | image_url: width: 240
              | image_tag: loading: 'lazy', widths: '120,180,240', alt: block.settings.title
            }}
          </div>
        {% endif %}
        {% if block.settings.title != blank %}
          <h3 class="storylio-slider__title">{{ block.settings.title }}</h3>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="storylio-slider__body rte">{{ block.settings.text }}</div>
        {% endif %}
      </article>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="storylio-slider__controls">
      <button class="storylio-slider__button" type="button" aria-label="Vorheriger Slide" data-storylio-slider-prev="{{ slider_id }}">
        &#8592;
      </button>
      <button class="storylio-slider__button" type="button" aria-label="Nächster Slide" data-storylio-slider-next="{{ slider_id }}">
        &#8594;
      </button>
    </div>
  {% endif %}
</section>

<script>
  (() => {
    const rail = document.getElementById('{{ slider_id }}');
    if (!rail) return;

    const card = rail.querySelector('.storylio-slider__card');
    if (!card) return;

    const scrollAmount = () => card.getBoundingClientRect().width + 18;
    const prev = document.querySelector('[data-storylio-slider-prev="{{ slider_id }}"]');
    const next = document.querySelector('[data-storylio-slider-next="{{ slider_id }}"]');

    prev?.addEventListener('click', () => {
      rail.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });

    next?.addEventListener('click', () => {
      rail.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "Storylio Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Loved by customers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Why buyers keep recommending it"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use short, high-trust reviews that remove objections and reinforce the buying decision.</p>"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "It feels premium from day one"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Short, specific, outcome-driven feedback converts better than vague praise.</p><p><strong>Anna, verified buyer</strong></p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Storylio Reviews",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
