{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign ai_page = product.metafields.ai_builder.page_json.value %}
{% assign ai_section = blank %}

{% if ai_page and ai_page.sections %}
  {% for page_section in ai_page.sections %}
    {% if page_section.type == 'benefits_grid' %}
      {% assign ai_section = page_section %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker %}
{% assign title = section.settings.title | strip | default: ai_section.title %}

{% if title != blank or eyebrow != blank or ai_section.items != blank or section.blocks.size > 0 %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__panel">
      {% if eyebrow != blank %}
        <p class="ai-builder-section__eyebrow">{{ eyebrow }}</p>
      {% endif %}
      {% if title != blank %}
        <h2 class="ai-builder-section__title">{{ title }}</h2>
      {% endif %}

      <div class="ai-builder-section__grid ai-builder-section__grid--cards">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% assign item_text = block.settings.text | strip %}
            {% if item_text != blank %}
              <div class="ai-builder-section__card" {{ block.shopify_attributes }}>
                <span class="ai-builder-section__dot"></span>
                <p>{{ item_text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        {% elsif ai_section.items != blank %}
          {% for item in ai_section.items %}
            {% assign item_text = item | strip %}
            {% if item_text != blank %}
              <div class="ai-builder-section__card">
                <span class="ai-builder-section__dot"></span>
                <p>{{ item_text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI Benefits Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Benefits Grid"
    }
  ]
}
{% endschema %}
