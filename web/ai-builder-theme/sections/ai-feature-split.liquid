{% liquid
  assign sid = section.id

  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width

  assign bg_mode = section.settings.bg_mode
  assign bg_color = section.settings.bg_color
  assign bg_gradient = section.settings.bg_gradient

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_side = section.settings.padding_side

  assign block_gap = section.settings.block_gap
  assign media_text_gap = section.settings.media_text_gap
  assign image_radius = section.settings.image_radius
  assign image_border_width = section.settings.image_border_width
  assign image_border_color = section.settings.image_border_color
  assign image_bg = section.settings.image_bg

  assign title_color = section.settings.title_color
  assign text_color = section.settings.text_color
  assign underline_color = section.settings.underline_color

  assign title_size = section.settings.title_size
  assign title_size_mobile = section.settings.title_size_mobile
  assign title_weight = section.settings.title_weight
  assign title_letter_spacing = section.settings.title_letter_spacing
  assign title_line_height = section.settings.title_line_height

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile
  assign text_line_height = section.settings.text_line_height
  assign text_max_width = section.settings.text_max_width

  assign content_padding_y = section.settings.content_padding_y
  assign animation_enabled = section.settings.animation_enabled
  assign reveal_distance = section.settings.reveal_distance
  assign reveal_duration = section.settings.reveal_duration
  assign reveal_delay_title = section.settings.reveal_delay_title
  assign reveal_delay_text = section.settings.reveal_delay_text
  assign underline_duration = section.settings.underline_duration
%}

<section
  id="ai-feature-split-{{ sid }}"
  class="ai-feature-split-section{% unless animation_enabled %} ai-feature-split-section--no-anim{% endunless %}"
  style="
    --afs-bg: {{ bg_color }};
    --afs-image-bg: {{ image_bg }};
    --afs-image-border-color: {{ image_border_color }};
    --afs-image-border-width: {{ image_border_width }}px;
    --afs-image-radius: {{ image_radius }}px;
    --afs-title-color: {{ title_color }};
    --afs-text-color: {{ text_color }};
    --afs-underline-color: {{ underline_color }};
    --afs-title-size: {{ title_size }}px;
    --afs-title-size-mobile: {{ title_size_mobile }}px;
    --afs-title-weight: {{ title_weight }};
    --afs-title-letter-spacing: {{ title_letter_spacing }}px;
    --afs-title-line-height: {{ title_line_height }};
    --afs-text-size: {{ text_size }}px;
    --afs-text-size-mobile: {{ text_size_mobile }}px;
    --afs-text-line-height: {{ text_line_height }};
    --afs-text-max-width: {{ text_max_width }}ch;
    --afs-block-gap: {{ block_gap }}px;
    --afs-media-text-gap: {{ media_text_gap }}px;
    --afs-content-padding-y: {{ content_padding_y }}px;
    --afs-reveal-distance: {{ reveal_distance }}px;
    --afs-reveal-duration: {{ reveal_duration }}ms;
    --afs-reveal-delay-title: {{ reveal_delay_title }}ms;
    --afs-reveal-delay-text: {{ reveal_delay_text }}ms;
    --afs-underline-duration: {{ underline_duration }}ms;
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_side }}px;
    padding-right: {{ padding_side }}px;
    {% if bg_mode == 'gradient' %}
      background: {{ bg_gradient }};
    {% else %}
      background: {{ bg_color }};
    {% endif %}
  "
>
  <div
    class="ai-feature-split__inner{% if section_width == 'custom' %} ai-feature-split__inner--custom{% endif %}{% if section_width == 'full' %} ai-feature-split__inner--full{% endif %}"
    {% if section_width == 'custom' %}
      style="max-width: {{ custom_width }}px;"
    {% endif %}
  >
    <div class="ai-feature-split__list">
      {% for block in section.blocks %}
        {% assign media_position = block.settings.media_position %}
        <article class="ai-feature-split__item ai-feature-split__item--media-{{ media_position }}" {{ block.shopify_attributes }}>
          <div class="ai-feature-split__media" data-afs-reveal="media">
            <div class="ai-feature-split__image-wrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    class: 'ai-feature-split__image',
                    widths: '400,600,800,1000,1200,1400',
                    sizes: '(min-width: 860px) 50vw, 100vw',
                    loading: 'lazy',
                    alt: block.settings.title | escape
                }}
              {% else %}
                <div class="ai-feature-split__placeholder">
                  <span>Bild hinzufügen</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div class="ai-feature-split__content">
            {% if block.settings.title != blank %}
              <h3 class="ai-feature-split__title" data-afs-reveal="title">
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="ai-feature-split__text" data-afs-reveal="text">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #ai-feature-split-{{ sid }} .ai-feature-split__inner {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__inner--full {
    max-width: 100%;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__list {
    display: grid;
    gap: var(--afs-block-gap);
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__item {
    display: grid;
    gap: var(--afs-media-text-gap);
    align-items: center;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__image-wrap {
    border-radius: var(--afs-image-radius);
    overflow: hidden;
    border: var(--afs-image-border-width) solid var(--afs-image-border-color);
    background: var(--afs-image-bg);
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__image {
    width: 100%;
    height: auto;
    display: block;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(0,0,0,0.04), rgba(0,0,0,0.08));
    color: rgba(0,0,0,0.45);
    font-size: 14px;
    font-weight: 600;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__content {
    padding: var(--afs-content-padding-y) 0;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__title {
    position: relative;
    display: inline-block;
    margin: 0 0 10px;
    color: var(--afs-title-color);
    font-size: var(--afs-title-size-mobile);
    font-weight: var(--afs-title-weight);
    line-height: var(--afs-title-line-height);
    letter-spacing: var(--afs-title-letter-spacing);
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 100%;
    height: 2px;
    background: var(--afs-underline-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--afs-underline-duration) ease;
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__text {
    margin: 0;
    max-width: var(--afs-text-max-width);
    color: var(--afs-text-color);
    font-size: var(--afs-text-size-mobile);
    line-height: var(--afs-text-line-height);
  }

  #ai-feature-split-{{ sid }} .ai-feature-split__text p {
    margin: 0;
  }

  #ai-feature-split-{{ sid }} [data-afs-reveal] {
    opacity: 0;
    transform: translateX(calc(var(--afs-reveal-distance) * -1));
    transition:
      opacity var(--afs-reveal-duration) ease,
      transform var(--afs-reveal-duration) ease;
    will-change: opacity, transform;
  }

  #ai-feature-split-{{ sid }} .afs-in[data-afs-reveal="media"] {
    opacity: 1;
    transform: translateX(0);
  }

  #ai-feature-split-{{ sid }} .afs-in[data-afs-reveal="title"] {
    opacity: 1;
    transform: translateX(0);
    transition-delay: var(--afs-reveal-delay-title);
  }

  #ai-feature-split-{{ sid }} .afs-in[data-afs-reveal="text"] {
    opacity: 1;
    transform: translateX(0);
    transition-delay: var(--afs-reveal-delay-text);
  }

  #ai-feature-split-{{ sid }} .afs-in.ai-feature-split__title::after {
    transform: scaleX(1);
    transition-delay: calc(var(--afs-reveal-delay-text) + 80ms);
  }

  #ai-feature-split-{{ sid }}.ai-feature-split-section--no-anim [data-afs-reveal] {
    opacity: 1;
    transform: none;
    transition: none;
  }

  #ai-feature-split-{{ sid }}.ai-feature-split-section--no-anim .ai-feature-split__title::after {
    transform: scaleX(1);
    transition: none;
  }

  @media (max-width: 859px) {
    #ai-feature-split-{{ sid }} .ai-feature-split__item {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 860px) {
    #ai-feature-split-{{ sid }} .ai-feature-split__item {
      grid-template-columns: 1.05fr 1fr;
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__item--media-right {
      grid-template-columns: 1fr 1.05fr;
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__item--media-right .ai-feature-split__media {
      order: 2;
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__item--media-right .ai-feature-split__content {
      order: 1;
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__title {
      font-size: var(--afs-title-size);
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__text {
      font-size: var(--afs-text-size);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ai-feature-split-{{ sid }} [data-afs-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }

    #ai-feature-split-{{ sid }} .ai-feature-split__title::after {
      transform: scaleX(1);
      transition: none;
    }
  }
</style>

<script>
  (function() {
    const root = document.getElementById('ai-feature-split-{{ sid }}');
    if (!root) return;

    if (root.classList.contains('ai-feature-split-section--no-anim')) return;

    const els = Array.from(root.querySelectorAll('[data-afs-reveal]'));
    if (!els.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('afs-in');
        observer.unobserve(entry.target);
      });
    }, {
      threshold: 0.18,
      rootMargin: '0px 0px -12% 0px'
    });

    els.forEach((el) => observer.observe(el));
  })();
</script>

{% schema %}
{
  "name": "AI Feature Split",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Breite"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Breite",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Breite",
      "min": 600,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1120
    },

    {
      "type": "header",
      "content": "Section Hintergrund"
    },
    {
      "type": "select",
      "id": "bg_mode",
      "label": "Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 100%)"
    },

    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "Abstand zwischen Blocks",
      "min": 0,
      "max": 60,
      "step": 2,
