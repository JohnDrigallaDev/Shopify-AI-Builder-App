{{ 'ai-builder-sections.css' | asset_url | stylesheet_tag }}

{% assign ai_page = product.metafields.ai_builder.page_json.value %}
{% assign ai_section = blank %}

{% if ai_page and ai_page.sections %}
  {% for page_section in ai_page.sections %}
    {% if page_section.type == 'feature_split' %}
      {% assign ai_section = page_section %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign eyebrow = section.settings.eyebrow | strip | default: ai_section.kicker %}
{% assign title = section.settings.title | strip | default: ai_section.title %}
{% assign body = section.settings.body | strip | default: ai_section.body %}

{% if eyebrow != blank or title != blank or body != blank or ai_section.items != blank or section.blocks.size > 0 %}
  <section class="ai-builder-section page-width">
    <div class="ai-builder-section__split">
      <div class="ai-builder-section__panel">
        {% if eyebrow != blank %}
          <p class="ai-builder-section__eyebrow">{{ eyebrow }}</p>
        {% endif %}
        {% if title != blank %}
          <h2 class="ai-builder-section__title">{{ title }}</h2>
        {% endif %}
        {% if body != blank %}
          <div class="ai-builder-section__body rte">{{ body | newline_to_br }}</div>
        {% endif %}
      </div>
      <div class="ai-builder-section__panel">
        <ul class="ai-builder-section__list">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% assign item_text = block.settings.text | strip %}
              {% if item_text != blank %}
                <li class="ai-builder-section__list-item" {{ block.shopify_attributes }}>
                  <span class="ai-builder-section__dot"></span>
                  <span>{{ item_text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          {% elsif ai_section.items != blank %}
            {% for item in ai_section.items %}
              {% assign item_text = item | strip %}
              {% if item_text != blank %}
                <li class="ai-builder-section__list-item">
                  <span class="ai-builder-section__dot"></span>
                  <span>{{ item_text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          {% endif %}
        </ul>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI Feature Split",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Feature Split"
    }
  ]
}
{% endschema %}
