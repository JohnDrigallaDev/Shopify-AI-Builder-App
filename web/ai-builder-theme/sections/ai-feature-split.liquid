    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Bild Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "image_border_width",
