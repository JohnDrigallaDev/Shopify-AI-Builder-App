{% liquid
  assign sid = section.id

  assign source_mode = section.settings.source_mode
  assign container_width = section.settings.container_width
  assign custom_width = section.settings.custom_width

  assign section_bg_mode = section.settings.section_bg_mode
  assign section_bg = section.settings.section_bg
  assign section_gradient = section.settings.section_gradient

  assign card_bg = section.settings.card_bg
  assign card_border_color = section.settings.card_border_color
  assign card_border_width = section.settings.card_border_width
  assign card_radius = section.settings.card_radius
  assign card_padding_y = section.settings.card_padding_y
  assign card_padding_x = section.settings.card_padding_x
  assign item_gap = section.settings.item_gap
  assign row_gap = section.settings.row_gap

  assign section_padding_top = section.settings.section_padding_top
  assign section_padding_bottom = section.settings.section_padding_bottom
  assign section_padding_side = section.settings.section_padding_side
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom

  assign icon_height = section.settings.icon_height
  assign icon_height_mobile = section.settings.icon_height_mobile
  assign icon_padding_x = section.settings.icon_padding_x
  assign icon_padding_y = section.settings.icon_padding_y
  assign icon_bg = section.settings.icon_bg
  assign icon_border_color = section.settings.icon_border_color
  assign icon_border_width = section.settings.icon_border_width
  assign icon_radius = section.settings.icon_radius

  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign heading_color = section.settings.heading_color

  assign align_desktop = section.settings.align_desktop
  assign align_mobile = section.settings.align_mobile

  assign show_heading = section.settings.show_heading
  assign show_wrapper = section.settings.show_wrapper

  assign manual_icons_raw = section.settings.manual_icons
  assign manual_icons = manual_icons_raw | downcase | strip_html | replace: '-', '_' | replace: ' ', '' | split: ','

  assign custom_icon_1 = section.settings.custom_icon_1
  assign custom_icon_2 = section.settings.custom_icon_2
  assign custom_icon_3 = section.settings.custom_icon_3
  assign custom_icon_4 = section.settings.custom_icon_4

  assign custom_icon_1_width = section.settings.custom_icon_1_width
  assign custom_icon_2_width = section.settings.custom_icon_2_width
  assign custom_icon_3_width = section.settings.custom_icon_3_width
  assign custom_icon_4_width = section.settings.custom_icon_4_width
%}

<section
  id="ai-payment-icons-{{ sid }}"
  class="ai-payment-icons-section"
  style="
    --api-section-bg: {{ section_bg }};
    --api-card-bg: {{ card_bg }};
    --api-card-border: {{ card_border_color }};
    --api-card-border-width: {{ card_border_width }}px;
    --api-card-radius: {{ card_radius }}px;
    --api-card-padding-y: {{ card_padding_y }}px;
    --api-card-padding-x: {{ card_padding_x }}px;
    --api-item-gap: {{ item_gap }}px;
    --api-row-gap: {{ row_gap }}px;
    --api-icon-height: {{ icon_height }}px;
    --api-icon-height-mobile: {{ icon_height_mobile }}px;
    --api-icon-padding-x: {{ icon_padding_x }}px;
    --api-icon-padding-y: {{ icon_padding_y }}px;
    --api-icon-bg: {{ icon_bg }};
    --api-icon-border: {{ icon_border_color }};
    --api-icon-border-width: {{ icon_border_width }}px;
    --api-icon-radius: {{ icon_radius }}px;
    --api-heading-size: {{ heading_size }}px;
    --api-heading-size-mobile: {{ heading_size_mobile }}px;
    --api-heading-color: {{ heading_color }};
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ section_padding_top }}px;
    padding-bottom: {{ section_padding_bottom }}px;
    padding-left: {{ section_padding_side }}px;
    padding-right: {{ section_padding_side }}px;
    {% if section_bg_mode == 'gradient' %}
      background: {{ section_gradient }};
    {% else %}
      background: var(--api-section-bg);
    {% endif %}
  "
>
  <div
    class="ai-payment-icons__inner{% if container_width == 'custom' %} ai-payment-icons__inner--custom{% endif %}{% if container_width == 'full' %} ai-payment-icons__inner--full{% endif %}"
    {% if container_width == 'custom' %}
      style="max-width: {{ custom_width }}px;"
    {% endif %}
  >
    {% if show_wrapper %}
      <div class="ai-payment-icons__box">
    {% endif %}

      {% if show_heading and heading != blank %}
        <h2 class="ai-payment-icons__heading">{{ heading }}</h2>
      {% endif %}

      <ul
        class="ai-payment-icons__list ai-payment-icons__list--desktop-{{ align_desktop }} ai-payment-icons__list--mobile-{{ align_mobile }}"
        role="list"
      >
        {% if source_mode == 'shopify' %}
          {% for type in shop.enabled_payment_types %}
            <li class="ai-payment-icons__item">
              <div class="ai-payment-icons__icon-holder">
                {{ type | payment_type_svg_tag: class: 'ai-payment-icons__svg' }}
              </div>
            </li>
          {% endfor %}
        {% else %}
          {% for type in manual_icons %}
            {% assign cleaned_type = type | strip %}
            {% if cleaned_type != blank %}
              <li class="ai-payment-icons__item">
                <div class="ai-payment-icons__icon-holder">
                  {{ cleaned_type | payment_type_svg_tag: class: 'ai-payment-icons__svg' }}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        {% endif %}

        {% if custom_icon_1 != blank %}
          <li class="ai-payment-icons__item">
            <div class="ai-payment-icons__icon-holder ai-payment-icons__icon-holder--custom">
              {{
                custom_icon_1
                | image_url: width: 300
                | image_tag:
                  class: 'ai-payment-icons__custom-image',
                  widths: '100,150,200,250,300',
                  loading: 'lazy',
                  alt: 'Custom payment icon 1',
                  style: 'width:' | append: custom_icon_1_width | append: 'px;'
              }}
            </div>
          </li>
        {% endif %}

        {% if custom_icon_2 != blank %}
          <li class="ai-payment-icons__item">
            <div class="ai-payment-icons__icon-holder ai-payment-icons__icon-holder--custom">
              {{
                custom_icon_2
                | image_url: width: 300
                | image_tag:
                  class: 'ai-payment-icons__custom-image',
                  widths: '100,150,200,250,300',
                  loading: 'lazy',
                  alt: 'Custom payment icon 2',
                  style: 'width:' | append: custom_icon_2_width | append: 'px;'
              }}
            </div>
          </li>
        {% endif %}

        {% if custom_icon_3 != blank %}
          <li class="ai-payment-icons__item">
            <div class="ai-payment-icons__icon-holder ai-payment-icons__icon-holder--custom">
              {{
                custom_icon_3
                | image_url: width: 300
                | image_tag:
                  class: 'ai-payment-icons__custom-image',
                  widths: '100,150,200,250,300',
                  loading: 'lazy',
                  alt: 'Custom payment icon 3',
                  style: 'width:' | append: custom_icon_3_width | append: 'px;'
              }}
            </div>
          </li>
        {% endif %}

        {% if custom_icon_4 != blank %}
          <li class="ai-payment-icons__item">
            <div class="ai-payment-icons__icon-holder ai-payment-icons__icon-holder--custom">
              {{
                custom_icon_4
                | image_url: width: 300
                | image_tag:
                  class: 'ai-payment-icons__custom-image',
                  widths: '100,150,200,250,300',
                  loading: 'lazy',
                  alt: 'Custom payment icon 4',
                  style: 'width:' | append: custom_icon_4_width | append: 'px;'
              }}
            </div>
          </li>
        {% endif %}
      </ul>

    {% if show_wrapper %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #ai-payment-icons-{{ sid }} .ai-payment-icons__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__inner--full {
    max-width: 100%;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__box {
    background: var(--api-card-bg);
    border: var(--api-card-border-width) solid var(--api-card-border);
    border-radius: var(--api-card-radius);
    padding: var(--api-card-padding-y) var(--api-card-padding-x);
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__heading {
    margin: 0 0 14px;
    color: var(--api-heading-color);
    font-size: var(--api-heading-size-mobile);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    text-align: center;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--api-row-gap) var(--api-item-gap);
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__list--mobile-left {
    justify-content: flex-start;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__list--mobile-center {
    justify-content: center;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__list--mobile-right {
    justify-content: flex-end;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__item {
    display: flex;
    align-items: center;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__icon-holder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--api-icon-height-mobile);
    padding: var(--api-icon-padding-y) var(--api-icon-padding-x);
    background: var(--api-icon-bg);
    border: var(--api-icon-border-width) solid var(--api-icon-border);
    border-radius: var(--api-icon-radius);
    line-height: 1;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__svg {
    height: var(--api-icon-height-mobile);
    width: auto;
    display: block;
  }

  #ai-payment-icons-{{ sid }} .ai-payment-icons__custom-image {
    height: auto;
    max-width: 100%;
    display: block;
  }

  @media screen and (min-width: 750px) {
    #ai-payment-icons-{{ sid }} .ai-payment-icons__heading {
      font-size: var(--api-heading-size);
    }

    #ai-payment-icons-{{ sid }} .ai-payment-icons__svg {
      height: var(--api-icon-height);
    }

    #ai-payment-icons-{{ sid }} .ai-payment-icons__icon-holder {
      min-height: var(--api-icon-height);
    }

    #ai-payment-icons-{{ sid }} .ai-payment-icons__list--desktop-left {
      justify-content: flex-start;
    }

    #ai-payment-icons-{{ sid }} .ai-payment-icons__list--desktop-center {
      justify-content: center;
    }

    #ai-payment-icons-{{ sid }} .ai-payment-icons__list--desktop-right {
      justify-content: flex-end;
    }
  }
</style>

{% schema %}
{
  "name": "AI Payment Icons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Quelle"
    },
    {
      "type": "select",
      "id": "source_mode",
      "label": "Icons Quelle",
      "default": "shopify",
      "options": [
        { "value": "shopify", "label": "Automatisch aus Shopify" },
        { "value": "manual", "label": "Manuell auswählen" }
      ]
    },
    {
      "type": "textarea",
      "id": "manual_icons",
      "label": "Manuelle Payment-Typen",
      "info": "Kommagetrennt, z. B.: visa, master, paypal, klarna, apple_pay, google_pay, american_express. Offizielle Keys: https://johndrigalladev.github.io/Shopify-Icon-Payments/",
      "default": "american_express, apple_pay, google_pay, paypal, master, maestro, klarna, visa"
    },
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Breite",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Breite",
      "min": 600,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Überschrift anzeigen",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Sichere Zahlungsmethoden"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Größe Desktop",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Größe Mobile",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Ausrichtung"
    },
    {
      "type": "select",
      "id": "align_desktop",
      "label": "Desktop",
      "default": "center",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    {
      "type": "select",
      "id": "align_mobile",
      "label": "Mobile",
      "default": "center",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    {
      "type": "header",
      "content": "Section Abstände"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_padding_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Wrapper"
    },
    {
      "type": "checkbox",
      "id": "show_wrapper",
      "label": "Wrapper Box anzeigen",
      "default": false
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "label": "Wrapper Padding oben/unten",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "label": "Wrapper Padding links/rechts",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Wrapper Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Wrapper Border",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Icon Layout"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Horizontaler Abstand",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Vertikaler Abstand",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_height",
      "label": "Icon Höhe Desktop",
      "min": 14,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_height_mobile",
      "label": "Icon Höhe Mobile",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_padding_x",
      "label": "Icon Padding links/rechts",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "icon_padding_y",
      "label": "Icon Padding oben/unten",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "icon_radius",
      "label": "Icon Radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "icon_border_width",
      "label": "Icon Border",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Custom Icons"
    },
    {
      "type": "image_picker",
      "id": "custom_icon_1",
      "label": "Custom Icon 1"
    },
    {
      "type": "range",
      "id": "custom_icon_1_width",
      "label": "Custom Icon 1 Breite",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "image_picker",
      "id": "custom_icon_2",
      "label": "Custom Icon 2"
    },
    {
      "type": "range",
      "id": "custom_icon_2_width",
      "label": "Custom Icon 2 Breite",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "image_picker",
      "id": "custom_icon_3",
      "label": "Custom Icon 3"
    },
    {
      "type": "range",
      "id": "custom_icon_3_width",
      "label": "Custom Icon 3 Breite",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "image_picker",
      "id": "custom_icon_4",
      "label": "Custom Icon 4"
    },
    {
      "type": "range",
      "id": "custom_icon_4_width",
      "label": "Custom Icon 4 Breite",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "select",
      "id": "section_bg_mode",
      "label": "Section Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "section_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 100%)"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Wrapper Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Wrapper Border Farbe",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon Border Farbe",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Überschrift Farbe",
      "default": "#111111"
    }
  ]
}
{% endschema %}
