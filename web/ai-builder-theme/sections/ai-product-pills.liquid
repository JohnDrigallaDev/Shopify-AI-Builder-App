{% liquid
  assign sid = section.id

  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_side = section.settings.padding_side

  assign bg_mode = section.settings.bg_mode
  assign bg_color = section.settings.bg_color
  assign bg_gradient = section.settings.bg_gradient

  assign list_align_desktop = section.settings.list_align_desktop
  assign list_align_mobile = section.settings.list_align_mobile
  assign gap_desktop = section.settings.gap_desktop
  assign gap_mobile = section.settings.gap_mobile

  assign pill_padding_y = section.settings.pill_padding_y
  assign pill_padding_x = section.settings.pill_padding_x
  assign pill_radius = section.settings.pill_radius
  assign pill_border_width = section.settings.pill_border_width
  assign pill_shadow_strength = section.settings.pill_shadow_strength

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile
  assign font_weight = section.settings.font_weight

  assign icon_size = section.settings.icon_size
  assign icon_size_mobile = section.settings.icon_size_mobile
  assign icon_gap = section.settings.icon_gap

  assign min_height = section.settings.min_height
  assign uppercase = section.settings.uppercase
%}

<section
  id="ai-product-pills-{{ sid }}"
  class="ai-product-pills-section"
  style="
    --app-gap-desktop: {{ gap_desktop }}px;
    --app-gap-mobile: {{ gap_mobile }}px;
    --app-pill-padding-y: {{ pill_padding_y }}px;
    --app-pill-padding-x: {{ pill_padding_x }}px;
    --app-pill-radius: {{ pill_radius }}px;
    --app-pill-border-width: {{ pill_border_width }}px;
    --app-pill-shadow: 0 {{ pill_shadow_strength | divided_by: 2.0 }}px {{ pill_shadow_strength | times: 2 }}px rgba(0,0,0,0.10);
    --app-text-size: {{ text_size }}px;
    --app-text-size-mobile: {{ text_size_mobile }}px;
    --app-font-weight: {{ font_weight }};
    --app-icon-size: {{ icon_size }}px;
    --app-icon-size-mobile: {{ icon_size_mobile }}px;
    --app-icon-gap: {{ icon_gap }}px;
    --app-min-height: {{ min_height }}px;
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_side }}px;
    padding-right: {{ padding_side }}px;
    {% if bg_mode == 'gradient' %}
      background: {{ bg_gradient }};
    {% else %}
      background: {{ bg_color }};
    {% endif %}
  "
>
  <div
    class="ai-product-pills__inner{% if section_width == 'custom' %} ai-product-pills__inner--custom{% endif %}{% if section_width == 'full' %} ai-product-pills__inner--full{% endif %}"
    {% if section_width == 'custom' %}
      style="max-width: {{ custom_width }}px;"
    {% endif %}
  >
    <div class="ai-product-pills__list ai-product-pills__list--desktop-{{ list_align_desktop }} ai-product-pills__list--mobile-{{ list_align_mobile }}">
      {% for block in section.blocks %}
        {% liquid
          assign pill_bg = block.settings.pill_bg
          assign pill_text_color = block.settings.pill_text_color
          assign pill_border_color = block.settings.pill_border_color
          assign custom_icon = block.settings.custom_icon
          assign emoji_icon = block.settings.emoji_icon
        %}

        <div class="ai-product-pills__item" {{ block.shopify_attributes }}>
          <div
            class="ai-product-pills__pill{% if uppercase %} is-uppercase{% endif %}"
            style="
              --app-pill-bg: {{ pill_bg }};
              --app-pill-text: {{ pill_text_color }};
              --app-pill-border: {{ pill_border_color }};
            "
          >
            {% if custom_icon != blank %}
              <span class="ai-product-pills__icon ai-product-pills__icon--image">
                {{
                  custom_icon
                  | image_url: width: 120
                  | image_tag:
                    class: 'ai-product-pills__icon-image',
                    widths: '40,60,80,120',
                    loading: 'lazy',
                    alt: block.settings.text | escape
                }}
              </span>
            {% elsif emoji_icon != blank %}
              <span class="ai-product-pills__icon ai-product-pills__icon--emoji">{{ emoji_icon }}</span>
            {% endif %}

            {% if block.settings.text != blank %}
              <span class="ai-product-pills__text">{{ block.settings.text }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #ai-product-pills-{{ sid }} .ai-product-pills__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__inner--full {
    max-width: 100%;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--app-gap-mobile);
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__list--mobile-left {
    justify-content: flex-start;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__list--mobile-center {
    justify-content: center;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__list--mobile-right {
    justify-content: flex-end;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__item {
    display: flex;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__pill {
    display: inline-flex;
    align-items: center;
    gap: var(--app-icon-gap);
    min-height: var(--app-min-height);
    padding: var(--app-pill-padding-y) var(--app-pill-padding-x);
    border-radius: var(--app-pill-radius);
    border: var(--app-pill-border-width) solid var(--app-pill-border);
    background: var(--app-pill-bg);
    color: var(--app-pill-text);
    box-shadow: var(--app-pill-shadow);
    line-height: 1;
    white-space: nowrap;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__pill.is-uppercase {
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--app-icon-size-mobile);
    min-width: var(--app-icon-size-mobile);
    height: var(--app-icon-size-mobile);
    line-height: 1;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__icon--emoji {
    font-size: calc(var(--app-icon-size-mobile) - 2px);
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #ai-product-pills-{{ sid }} .ai-product-pills__text {
    font-size: var(--app-text-size-mobile);
    font-weight: var(--app-font-weight);
    line-height: 1.1;
  }

  @media screen and (min-width: 750px) {
    #ai-product-pills-{{ sid }} .ai-product-pills__list {
      gap: var(--app-gap-desktop);
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__list--desktop-left {
      justify-content: flex-start;
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__list--desktop-center {
      justify-content: center;
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__list--desktop-right {
      justify-content: flex-end;
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__icon {
      width: var(--app-icon-size);
      min-width: var(--app-icon-size);
      height: var(--app-icon-size);
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__icon--emoji {
      font-size: calc(var(--app-icon-size) - 2px);
    }

    #ai-product-pills-{{ sid }} .ai-product-pills__text {
      font-size: var(--app-text-size);
    }
  }
</style>

{% schema %}
{
  "name": "AI Product Pills",
  "tag": "section",
  "class": "section",
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "Breite"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Breite",
      "default": "full",
      "options": [
        { "value": "page", "label": "Page width" },
        { "value": "full", "label": "Volle Breite" },
        { "value": "custom", "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Breite",
      "min": 280,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 900
    },

    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin oben",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin unten",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_side",
      "label": "Padding Seite",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "Ausrichtung & Abstand"
    },
    {
      "type": "select",
      "id": "list_align_desktop",
      "label": "Desktop Ausrichtung",
      "default": "left",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    {
      "type": "select",
      "id": "list_align_mobile",
      "label": "Mobile Ausrichtung",
      "default": "left",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap Desktop",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap Mobile",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },

    {
      "type": "header",
      "content": "Pill Layout"
    },
    {
      "type": "range",
      "id": "pill_padding_y",
      "label": "Padding oben/unten",
      "min": 4,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 9
    },
    {
      "type": "range",
      "id": "pill_padding_x",
      "label": "Padding links/rechts",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "pill_radius",
      "label": "Radius",
      "min": 8,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "pill_border_width",
      "label": "Border",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "pill_shadow_strength",
      "label": "Shadow Stärke",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Mindesthöhe",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 38
    },

    {
      "type": "header",
      "content": "Typografie & Icons"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Textgröße Desktop",
      "min": 11,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Textgröße Mobile",
      "min": 11,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Schriftstärke",
      "default": "500",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Alles in Großbuchstaben",
      "default": false
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Größe Desktop",
      "min": 12,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon Größe Mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "icon_gap",
      "label": "Abstand Icon/Text",
      "min": 4,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 8
    },

    {
      "type": "header",
      "content": "Section Hintergrund"
    },
    {
      "type": "select",
      "id": "bg_mode",
      "label": "Hintergrund",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Einfarbig" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 100%)"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Product Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Vegan"
        },
        {
          "type": "text",
          "id": "emoji_icon",
          "label": "Emoji Icon",
          "default": "🌱"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Eigenes Icon (überschreibt Emoji)"
        },
        {
          "type": "color",
          "id": "pill_bg",
          "label": "Hintergrund",
          "default": "#b8efb6"
        },
        {
          "type": "color",
          "id": "pill_text_color",
          "label": "Textfarbe",
          "default": "#2d6b2f"
        },
        {
          "type": "color",
          "id": "pill_border_color",
          "label": "Border Farbe",
          "default": "#b8efb6"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
