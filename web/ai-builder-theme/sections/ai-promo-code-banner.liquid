    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Banner Border",
      "default": "#c992f4"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Farbe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_text_color",
