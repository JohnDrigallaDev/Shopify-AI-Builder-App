    "ai_section_1": {
      "type": "ai-feature-split",
      "settings": {
        "bg_color": "#F4F4F5",
        "title_color": "#111111",
        "text_color": "#333333",
        "underline_color": "#2B2B2F"
      },
      "blocks": {
        "feature_1": {
          "type": "feature",
          "settings": {
            "media_position": "left",
            "title": "Jedes Putzen kostet doppelt Zeit.",
            "text": "<p>Ein Gerät nur zum Saugen, eines nur zum Wischen, dazu ständig wechseln und nachfüllen. So wird aus einem kurzen Reinigungsjob schnell eine halbe Stunde Aufwand. Im Alltag bremst genau das, was eigentlich helfen soll.</p>"
          }
        },
        "feature_2": {
          "type": "feature",
          "settings": {
            "media_position": "right",
            "title": "Ein Gerät für trockenen und nassen Schmutz.",
            "text": "<p>Der Hearten Nass Trockensauger kombiniert Saugen und Wischen in einem Arbeitsgang. So werden Laminat, Fliesen und Vinyl schneller sauber, ohne dass du mehrere Schritte planen musst.</p>"
          }
        },
        "feature_3": {
          "type": "feature",
          "settings": {
            "media_position": "left",
            "title": "10.000+ Haushalte setzen auf diese Lösung.",
            "text": "<p>Immer mehr Käufer suchen genau nach dieser Art von Bodenreinigung: schnell, praktisch und ohne doppelten Aufwand. Das Ergebnis ist ein sauberer Boden mit weniger Stress im Alltag.</p>"
          }
        }
      },
      "block_order": [
        "feature_1",
        "feature_2",
        "feature_3"
      ]
