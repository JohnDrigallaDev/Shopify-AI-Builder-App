            "ai_acc_item_2_show": true,
            "ai_acc_item_2_icon": "rueckgabe",
            "ai_acc_item_2_title": "Rückgabe",
            "ai_acc_item_2_content": "<p>Du kannst deine Bestellung innerhalb von 30 Tagen zurückgeben, sofern sie unbenutzt und vollständig ist. Kontaktiere dafür einfach unseren Support.</p>",
            "ai_acc_item_3_show": true,
