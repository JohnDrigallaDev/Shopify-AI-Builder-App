    "ai_section_2": {
      "type": "ai-feature-split",
      "settings": {
      },
      "blocks": {
        "feature_1": {
          "type": "feature",
          "settings": {
            "media_position": "left",
            "title": "Ständig Termine? Genau das bremst dich aus.",
            "text": "<p>Studio-Besuche kosten nicht nur Geld, sondern auch Zeit und Planung. Wenn du arbeiten, Familie und Alltag unter einen Hut bringen musst, wird jede Behandlung zur Zusatzaufgabe. Viele brechen deshalb einfach wieder ab.</p>"
          }
        },
        "feature_2": {
          "type": "feature",
          "settings": {
            "media_position": "right",
            "title": "KODO macht Haarentfernung zuhause einfach.",
            "text": "<p>Mit dem 4-in-1-Konzept erledigst du deine Routine bequem in den eigenen vier Wänden. Das Gerät ist auf Gesicht und Körper ausgelegt und hilft dir, Behandlung und Alltag besser zu kombinieren.</p>"
          }
        },
        "feature_3": {
          "type": "feature",
          "settings": {
            "media_position": "left",
            "title": "Mehr als 2.000 Käufer haben sich dafür entschieden.",
            "text": "<p>Die Produktseite zeigt bereits über 2.000 Bestellungen. Viele entscheiden sich genau deshalb für eine Lösung, die zuhause nutzbar ist und den Fokus auf einfache, wiederholbare Anwendung legt.</p>"
          }
        }
      },
      "block_order": [
        "feature_1",
        "feature_2",
        "feature_3"
      ]
    },
